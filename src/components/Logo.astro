---
import { SITE } from '~/utils/astrowind-config';
---

<div class="flex items-center gap-2">
  <img
    src="/logo.png"
    alt={SITE?.name || 'Depo Hire'}
    class="h-8 md:h-10 w-auto"
  />
  <div class="hidden sm:flex flex-col leading-tight">
    <span class="font-heading font-bold text-sm md:text-base tracking-wide text-primary-900">DEPO HIRE</span>
    <span class="text-[9px] md:text-[10px] tracking-[0.15em] uppercase text-muted font-medium">Deposition Videographer Directory</span>
  </div>
</div>
