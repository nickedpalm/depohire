---
import ReviewStars from './ReviewStars.astro';
import ClaimBanner from './ClaimBanner.astro';
import ReviewHighlights from './ReviewHighlights.astro';
import SentimentBadge from './SentimentBadge.astro';
import InitialsAvatar from './InitialsAvatar.astro';
import config from '~/config';
import citiesJson from '~/data/cities.json';
import type { Sentiment } from '~/lib/listings';

interface Props {
  listing: {
    slug: string;
    name: string;
    city: string;
    state: string;
    address: string;
    lat: number;
    lng: number;
    phone?: string;
    website?: string;
    email?: string;
    rating: number;
    review_count: number;
    description?: string;
    certifications?: string[];
    services?: string[];
    years_experience?: number;
    claimed: boolean;
    sentiment?: Sentiment | null;
  };
}

const { listing } = Astro.props;
const cityData = citiesJson.find((c: any) => c.slug === listing.city);

const hasCerts = listing.certifications && listing.certifications.length > 0;
const hasServices = listing.services && listing.services.length > 0;
const hasExperience = !!listing.years_experience;
const hasTabs = hasCerts || hasServices || hasExperience;

// Build tab list dynamically
const tabs: Array<{ id: string; label: string }> = [];
if (hasServices) tabs.push({ id: 'services', label: 'Services' });
if (hasCerts) tabs.push({ id: 'certifications', label: 'Certifications' });
if (hasExperience) tabs.push({ id: 'experience', label: 'Experience' });
---
<div class="space-y-6">
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
    <div class="flex items-center gap-4">
      <InitialsAvatar name={listing.name} size="lg" />
      <div>
      <h1 class="text-4xl font-heading font-bold text-gray-900">{listing.name}</h1>
      <p class="text-gray-500 mt-1">{listing.address}</p>
      <div class="mt-2 flex items-center gap-3">
        <ReviewStars rating={listing.rating} count={listing.review_count} />
        {listing.sentiment && <SentimentBadge label={listing.sentiment.label} score={listing.sentiment.score} />}
      </div>
      </div>
    </div>
    <div class="flex flex-col gap-2 sm:items-end">
      {listing.phone && (
        <a href={`tel:${listing.phone}`} class="btn-primary no-underline text-center">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          {listing.phone}
        </a>
      )}
      {listing.website && (
        <a href={listing.website} target="_blank" rel="noopener noreferrer" class="btn-outline no-underline text-center">
          Visit Website
        </a>
      )}
    </div>
  </div>

  {listing.description && (
    <div class="prose max-w-none">
      <p>{listing.description}</p>
    </div>
  )}

  {/* Tabbed interface */}
  {hasTabs && (
    <div>
      <div class="border-b border-gray-200 mb-4" id="detail-tabs">
        <nav class="flex gap-6" role="tablist">
          {tabs.map((tab, i) => (
            <button
              role="tab"
              class={`detail-tab ${i === 0 ? 'active' : ''}`}
              data-tab={tab.id}
              aria-selected={i === 0 ? 'true' : 'false'}
            >
              {tab.label}
            </button>
          ))}
        </nav>
      </div>

      {hasServices && (
        <div id="panel-services" class="detail-panel" data-panel="services">
          <div class="flex flex-wrap gap-1.5">
            {listing.services!.map((svc) => (
              <span class="inline-flex items-center px-2.5 py-1 rounded-md text-sm font-medium bg-primary-50 text-primary-700">{svc}</span>
            ))}
          </div>
        </div>
      )}

      {hasCerts && (
        <div id="panel-certifications" class={`detail-panel ${tabs[0]?.id !== 'certifications' ? 'hidden' : ''}`} data-panel="certifications">
          <div class="flex flex-wrap gap-1.5">
            {listing.certifications!.map((cert) => (
              <span class="inline-flex items-center px-2.5 py-1 rounded-md text-sm font-medium bg-accent-50 text-accent-800">{cert}</span>
            ))}
          </div>
        </div>
      )}

      {hasExperience && (
        <div id="panel-experience" class={`detail-panel ${tabs[0]?.id !== 'experience' ? 'hidden' : ''}`} data-panel="experience">
          <p class="text-2xl font-heading font-bold text-gray-900">{listing.years_experience}+ years</p>
          <p class="text-sm text-muted mt-1">of professional experience</p>
        </div>
      )}
    </div>
  )}

  <!-- Sentiment & Review Highlights -->
  {listing.sentiment && (
    <ReviewHighlights
      label={listing.sentiment.label}
      score={listing.sentiment.score}
      keywords={listing.sentiment.keywords}
      highlights={listing.sentiment.highlights}
      summary={listing.sentiment.summary}
    />
  )}

  <!-- Map -->
  <div class="card overflow-hidden">
    <div id="listing-map" class="h-64 w-full" data-lat={listing.lat} data-lng={listing.lng} data-name={listing.name}></div>
  </div>

  {!listing.claimed && <ClaimBanner listingName={listing.name} />}
</div>

<script is:inline>
  // Tab switching
  (function() {
    const container = document.getElementById('detail-tabs');
    if (!container) return;
    const tabs = container.querySelectorAll('.detail-tab');
    const panels = document.querySelectorAll('.detail-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;
        tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');
        panels.forEach(p => {
          if (p.dataset.panel === target) {
            p.classList.remove('hidden');
          } else {
            p.classList.add('hidden');
          }
        });
      });
    });
  })();

  // Lazy-load map
  (function() {
    const el = document.getElementById('listing-map');
    if (!el) return;
    let loaded = false;
    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting && !loaded) {
        loaded = true;
        observer.disconnect();
        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = 'https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.min.css';
        document.head.appendChild(link);
        const script = document.createElement('script');
        script.src = 'https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.min.js';
        script.onload = function() {
          const lat = parseFloat(el.dataset.lat);
          const lng = parseFloat(el.dataset.lng);
          const name = el.dataset.name;
          const map = L.map(el).setView([lat, lng], 14);
          L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap contributors'
          }).addTo(map);
          L.marker([lat, lng]).addTo(map).bindPopup(name).openPopup();
        };
        document.head.appendChild(script);
      }
    }, { rootMargin: '200px' });
    observer.observe(el);
  })();
</script>
