---
/**
 * HomeMap — homepage section featuring the interactive US coverage map
 * + a compact top-cities grid below it. Replaces the plain CityGrid on the homepage.
 */
import USMap from '~/components/directory/USMap.astro';
import config from '~/config';

interface CityEntry {
  slug: string;
  city: string;
  state: string;
  listingCount: number;
}

interface Props {
  cities: CityEntry[];
  totalCities: number;
  totalStates: number;
}

const { cities, totalCities, totalStates } = Astro.props;

// Top 12 cities by listing count for the quick-link grid below the map
const topCities = [...cities].sort((a, b) => b.listingCount - a.listingCount).slice(0, 12);
---

<section class="py-14 bg-gradient-to-b from-white to-primary-50/40">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    {/* Section header */}
    <div class="text-center mb-6">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-2">
        Coverage across the country
      </h2>
      <p class="text-muted text-sm max-w-xl mx-auto">
        Find verified deposition videographers in <strong class="text-gray-700">{totalCities}+ cities</strong> across <strong class="text-gray-700">{totalStates} states</strong>. Click any state to browse providers near you.
      </p>
    </div>

    {/* Map card */}
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4 sm:p-6 mb-6">
      <USMap />

      {/* Legend */}
      <div class="flex flex-wrap items-center justify-center gap-4 mt-4 pt-4 border-t border-gray-100">
        <span class="text-xs text-gray-500 font-medium">Providers per state:</span>
        <span class="flex items-center gap-1.5 text-xs text-gray-600">
          <span class="inline-block w-3 h-3 rounded-sm bg-gray-200 border border-gray-300"></span>
          None yet
        </span>
        <span class="flex items-center gap-1.5 text-xs text-gray-600">
          <span class="inline-block w-3 h-3 rounded-sm bg-sky-100 border border-sky-200"></span>
          1–4
        </span>
        <span class="flex items-center gap-1.5 text-xs text-gray-600">
          <span class="inline-block w-3 h-3 rounded-sm bg-sky-300 border border-sky-400"></span>
          5–8
        </span>
        <span class="flex items-center gap-1.5 text-xs text-gray-600">
          <span class="inline-block w-3 h-3 rounded-sm bg-sky-500 border border-sky-600"></span>
          9+
        </span>
        <a href="/states/all/" class="ml-2 text-xs font-semibold text-accent-600 hover:text-accent-700 underline underline-offset-2">
          Full coverage map →
        </a>
      </div>
    </div>

    {/* Top cities quick-links */}
    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 text-center mb-3">Popular cities</p>
      <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-2">
        {topCities.map((c) => (
          <a
            href={`/${c.slug}/`}
            class="group flex flex-col items-center justify-center bg-white hover:bg-accent-50 border border-gray-100 hover:border-accent-200 rounded-xl px-2 py-3 text-center transition-colors no-underline"
          >
            <span class="text-sm font-semibold text-gray-800 group-hover:text-accent-600 leading-tight">{c.city}</span>
            <span class="text-xs text-gray-400 mt-0.5">{c.state}</span>
            {c.listingCount > 0 && (
              <span class="text-xs text-accent-500 mt-1">{c.listingCount} listed</span>
            )}
          </a>
        ))}
      </div>

      {/* See all link */}
      <div class="text-center mt-5">
        <a href="/states/all/" class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent-600 hover:text-accent-700 transition-colors">
          Browse all {totalCities}+ cities
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>

  </div>
</section>
