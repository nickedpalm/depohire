---
interface Pin {
  lat: number;
  lng: number;
  name: string;
  slug: string;
}

interface Props {
  pins: Pin[];
  centerLat: number;
  centerLng: number;
  zoom?: number;
}

const { pins, centerLat, centerLng, zoom = 11 } = Astro.props;
---
<div class="card overflow-hidden">
  <div
    id="city-map"
    class="h-80 w-full"
    data-center-lat={centerLat}
    data-center-lng={centerLng}
    data-zoom={zoom}
    data-pins={JSON.stringify(pins)}
  ></div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css" />
<script is:inline src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const el = document.getElementById('city-map');
    if (!el) return;
    const lat = parseFloat(el.dataset.centerLat);
    const lng = parseFloat(el.dataset.centerLng);
    const zoom = parseInt(el.dataset.zoom);
    const pins = JSON.parse(el.dataset.pins || '[]');

    const map = L.map(el).setView([lat, lng], zoom);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);

    pins.forEach(pin => {
      L.marker([pin.lat, pin.lng])
        .addTo(map)
        .bindPopup(`<a href="/listing/${pin.slug}/">${pin.name}</a>`);
    });

    if (pins.length > 1) {
      const group = L.featureGroup(pins.map(p => L.marker([p.lat, p.lng])));
      map.fitBounds(group.getBounds().pad(0.1));
    }
  });
</script>
