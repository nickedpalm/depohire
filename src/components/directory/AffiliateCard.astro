---
interface Props {
  name: string;
  description: string;
  url: string;
  badge?: string;
  badgeColor?: 'blue' | 'green' | 'purple' | 'amber';
  logoText?: string;
}

const { name, description, url, badge, badgeColor = 'blue', logoText } = Astro.props;

const badgeStyles = {
  blue: 'bg-blue-100 text-blue-800',
  green: 'bg-green-100 text-green-800',
  purple: 'bg-purple-100 text-purple-800',
  amber: 'bg-amber-100 text-amber-800',
};
---
<a
  href={url}
  target="_blank"
  rel="noopener noreferrer sponsored"
  class="not-prose flex items-start gap-4 p-4 rounded-xl border border-gray-200 bg-white hover:border-accent-300 hover:shadow-sm transition-all group no-underline"
>
  <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-gray-100 flex items-center justify-center text-sm font-bold text-gray-600 group-hover:bg-accent-50">
    {logoText || name.slice(0, 2).toUpperCase()}
  </div>
  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-2 mb-0.5">
      <span class="font-semibold text-gray-900 group-hover:text-accent-700">{name}</span>
      {badge && (
        <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${badgeStyles[badgeColor]}`}>
          {badge}
        </span>
      )}
    </div>
    <p class="text-sm text-gray-600 leading-snug">{description}</p>
  </div>
  <div class="flex-shrink-0 text-gray-400 group-hover:text-accent-500 mt-0.5">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10M7 17L17 7"/></svg>
  </div>
</a>
