  {/* ─── Scripts ─────────────────────────────────────────────── */}
  <script>
    // Sticky CTA: show after scrolling past hero
    const stickyCta = document.getElementById('sticky-cta');
    const pricingCards = document.getElementById('pricing-cards');
    if (stickyCta && pricingCards) {
      const observer = new IntersectionObserver(([entry]) => {
        stickyCta.classList.toggle('translate-y-full', entry.isIntersecting);
        stickyCta.classList.toggle('translate-y-0', !entry.isIntersecting);
      }, { threshold: 0.1 });
      observer.observe(pricingCards);
    }

    // Tab switching
    document.querySelectorAll('.preview-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = (btn as HTMLElement).dataset.tab;
        document.querySelectorAll('.preview-tab').forEach(b => {
          b.classList.remove('border-primary-500', 'bg-primary-50', 'text-primary-700', 'border-2');
          b.classList.add('border-gray-300', 'text-gray-600');
        });
        btn.classList.add('border-primary-500', 'bg-primary-50', 'text-primary-700', 'border-2');
        btn.classList.remove('border-gray-300');
        document.getElementById('preview-standard')?.classList.toggle('hidden', tab !== 'standard');
        document.getElementById('preview-featured')?.classList.toggle('hidden', tab !== 'featured');
      });
    });

    // Lightbox
    function openLightbox(type: string) {
      const lb = document.getElementById('listing-lightbox');
      document.getElementById('lightbox-standard')?.classList.toggle('hidden', type !== 'standard');
      document.getElementById('lightbox-featured')?.classList.toggle('hidden', type !== 'featured');
      lb?.classList.remove('hidden');
      lb?.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }
    function closeLightbox() {
      const lb = document.getElementById('listing-lightbox');
      lb?.classList.add('hidden');
      lb?.classList.remove('flex');
      document.body.style.overflow = '';
    }
    document.getElementById('listing-lightbox')?.addEventListener('click', e => {
      if (e.target === e.currentTarget) closeLightbox();
    });
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') closeLightbox();
    });
    (window as any).openLightbox = openLightbox;
    (window as any).closeLightbox = closeLightbox;
  </script>

