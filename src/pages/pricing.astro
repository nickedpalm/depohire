---
import PageLayout from '~/layouts/PageLayout.astro';
import Breadcrumbs from '~/components/directory/Breadcrumbs.astro';
import config from '~/config';

const title = `Get More Deposition Clients — ${config.name} Featured Listings`;
const description = `Attorneys in your city are searching for a deposition videographer right now. A Featured listing on DepoHire puts you first. From $79/month, no contracts.`;
const metadata = { title, description };

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description,
  url: `${config.siteUrl}/pricing/`,
};
---

<PageLayout metadata={metadata}>
  <Fragment slot="announcement"><span></span></Fragment>

  {/* ─── Sticky CTA bar (appears after scroll) ──────────────── */}
  <div id="sticky-cta" class="fixed bottom-0 left-0 right-0 z-40 translate-y-full transition-transform duration-300 bg-primary-700 border-t border-primary-600 shadow-2xl px-4 py-3">
    <div class="max-w-5xl mx-auto flex items-center justify-between gap-4">
      <p class="text-white text-sm font-medium hidden sm:block">Ready to start getting attorney leads in your city?</p>
      <a href="/advertise/?plan=featured" class="flex-shrink-0 bg-white text-primary-800 font-bold px-5 py-2.5 rounded-xl text-sm hover:bg-primary-50 transition w-full sm:w-auto text-center">
        Get Featured — $79/mo →
      </a>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <Breadcrumbs crumbs={[{ label: 'For Providers' }]} />

    {/* ─── StoryBrand Hero: Problem → Stakes → Solution ────── */}
    <div class="text-center mb-10">
      <p class="text-xs font-semibold uppercase tracking-widest text-accent-600 mb-4">For Deposition Videographers</p>
      <h1 class="text-3xl sm:text-4xl font-bold text-default leading-tight mb-5">
        Attorneys in your city are searching<br class="hidden sm:block"/> for a videographer <em class="not-italic text-primary-600">right now.</em>
      </h1>
      <p class="text-lg text-muted max-w-2xl mx-auto mb-2">
        Without a Featured listing, they find your competitor first. With one, the call comes to you.
      </p>
      <p class="text-sm text-muted max-w-xl mx-auto">
        DepoHire is the only directory built specifically for deposition videographers. No clutter. No competing categories. Just attorneys who need exactly what you offer.
      </p>
    </div>

    {/* ─── Social proof bar ───────────────────────────────────── */}
    <div class="bg-primary-50 border border-primary-100 rounded-2xl px-6 py-4 mb-12 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-center">
      <div>
        <span class="text-2xl font-extrabold text-primary-700">50+</span>
        <span class="text-sm text-muted ml-1.5">cities covered</span>
      </div>
      <div class="hidden sm:block w-px h-6 bg-primary-200"></div>
      <div>
        <span class="text-2xl font-extrabold text-primary-700">1,000+</span>
        <span class="text-sm text-muted ml-1.5">monthly attorney searches</span>
      </div>
      <div class="hidden sm:block w-px h-6 bg-primary-200"></div>
      <div>
        <span class="text-2xl font-extrabold text-primary-700">2–3</span>
        <span class="text-sm text-muted ml-1.5">featured slots per city max</span>
      </div>
      <div class="hidden sm:block w-px h-6 bg-primary-200"></div>
      <div>
        <span class="text-2xl font-extrabold text-primary-700">$0</span>
        <span class="text-sm text-muted ml-1.5">setup fees, ever</span>
      </div>
    </div>

    {/* ─── Scarcity callout ───────────────────────────────────── */}
    <div class="bg-amber-50 border border-amber-300 rounded-xl px-5 py-3 mb-10 flex items-start gap-3">
      <svg class="w-5 h-5 text-amber-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
      <p class="text-sm text-amber-800"><strong>Limited availability:</strong> We cap Featured listings at 2–3 per city to protect the value of each placement. If your city is full, you'll be added to the waitlist.</p>
    </div>

    {/* ─── Pricing Cards ──────────────────────────────────────── */}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10" id="pricing-cards">

      {/* Basic */}
      <div class="relative rounded-2xl border-2 border-gray-200 bg-white p-7 flex flex-col">
        <div class="mb-5">
          <h2 class="font-bold text-lg mb-1 text-default">Basic Listing</h2>
          <div class="flex items-baseline gap-1 mb-2">
            <span class="text-3xl font-extrabold text-default">Free</span>
          </div>
          <p class="text-sm text-muted leading-snug">You exist in the directory, but you're on your own.</p>
        </div>
        <ul class="space-y-2.5 mb-6 flex-1">
          {['Listed in your city directory', 'Business name, address & phone', 'Link to your website', 'Alphabetical sort order'].map(f => (
            <li class="flex items-start gap-2 text-sm text-default">
              <svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              {f}
            </li>
          ))}
          {['No top placement — you compete with everyone', 'Leads go nowhere — no routing to your inbox', 'No editorial mention or backlink'].map(f => (
            <li class="flex items-start gap-2 text-sm text-gray-400">
              <svg class="w-4 h-4 text-gray-300 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              {f}
            </li>
          ))}
        </ul>
        <a href="/advertise/" class="w-full text-center py-2.5 rounded-xl text-sm font-semibold border border-gray-300 hover:border-primary-400 text-default hover:text-primary-700 transition">
          Claim Free Listing
        </a>
      </div>

      {/* Featured — highlighted */}
      <div class="relative rounded-2xl border-2 border-primary-500 bg-primary-50 shadow-xl shadow-primary-100 p-7 flex flex-col">
        <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 px-3 py-0.5 rounded-full text-xs font-bold tracking-wide bg-primary-600 text-white whitespace-nowrap">
          ⭐ Most Popular — Limited Slots
        </span>
        <div class="mb-5">
          <h2 class="font-bold text-lg mb-1 text-primary-900">Featured Listing</h2>
          <div class="flex items-baseline gap-1 mb-2">
            <span class="text-3xl font-extrabold text-default">$79</span>
            <span class="text-muted text-sm">/month</span>
          </div>
          <p class="text-sm text-muted leading-snug">Attorneys in your city see <strong>you first</strong>. Leads route directly to your inbox.</p>
        </div>
        <ul class="space-y-2.5 mb-6 flex-1">
          {[
            'Pinned to #1 in your city results',
            '"Featured" badge — stands out immediately',
            'Quote requests emailed directly to you',
            'Extended bio + full service list',
            'Direct link to your booking page',
            'CLVS certification badge (if applicable)',
            'Monthly impressions report',
          ].map(f => (
            <li class="flex items-start gap-2 text-sm text-default">
              <svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              {f}
            </li>
          ))}
        </ul>
        <a href="/advertise/?plan=featured" class="w-full text-center py-3 rounded-xl text-sm font-bold bg-primary-600 hover:bg-primary-700 text-white transition">
          Get Featured — $79/mo →
        </a>
        <p class="text-xs text-center text-primary-500 mt-2">No credit card needed to apply · Goes live in 2–3 days</p>
      </div>

      {/* City Pro */}
      <div class="relative rounded-2xl border-2 border-gray-200 bg-white p-7 flex flex-col">
        <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 px-3 py-0.5 rounded-full text-xs font-bold tracking-wide bg-amber-400 text-amber-900">
          Best Value
        </span>
        <div class="mb-5">
          <h2 class="font-bold text-lg mb-1 text-default">City Pro</h2>
          <div class="flex items-baseline gap-1 mb-2">
            <span class="text-3xl font-extrabold text-default">$149</span>
            <span class="text-muted text-sm">/month</span>
          </div>
          <p class="text-sm text-muted leading-snug">Own your market. Top listing + editorial SEO + newsletter placement.</p>
        </div>
        <ul class="space-y-2.5 mb-6 flex-1">
          {[
            'Everything in Featured',
            'Named in our "Best in [City]" guide',
            'Dofollow backlink to your website',
            'Sponsor slot in monthly attorney email',
            'Priority onboarding & support',
            'Quarterly performance review call',
          ].map(f => (
            <li class="flex items-start gap-2 text-sm text-default">
              <svg class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              {f}
            </li>
          ))}
        </ul>
        <a href="/advertise/?plan=citypro" class="w-full text-center py-2.5 rounded-xl text-sm font-semibold bg-amber-400 hover:bg-amber-500 text-amber-900 transition">
          Get City Pro — $149/mo →
        </a>
        <p class="text-xs text-center text-muted mt-2">Additional cities $49/mo each</p>
      </div>
    </div>

    {/* ─── ROI callout ─────────────────────────────────────────── */}
    <div class="bg-gradient-to-br from-primary-900 to-primary-700 rounded-2xl p-8 text-white mb-14">
      <h2 class="text-xl font-bold mb-2 text-center">One job pays for a full year.</h2>
      <p class="text-center text-primary-200 text-sm mb-8">The average deposition job pays $200–400. A Featured listing costs $79/month — or $948/year.<br/>One booked job from DepoHire and you're profitable for the rest of the year.</p>
      <div class="grid sm:grid-cols-3 gap-6 text-center mb-8">
        <div class="bg-white/10 rounded-xl p-4">
          <p class="text-3xl font-extrabold text-white mb-1">$200–400</p>
          <p class="text-sm text-primary-200 leading-snug">Avg. revenue per deposition job</p>
        </div>
        <div class="bg-white/10 rounded-xl p-4">
          <p class="text-3xl font-extrabold text-white mb-1">1 job</p>
          <p class="text-sm text-primary-200 leading-snug">Covers your listing for 3–5 months</p>
        </div>
        <div class="bg-white/10 rounded-xl p-4">
          <p class="text-3xl font-extrabold text-white mb-1">$0</p>
          <p class="text-sm text-primary-200 leading-snug">Setup fee. No contracts. Cancel anytime.</p>
        </div>
      </div>
      <div class="text-center">
        <a href="/advertise/?plan=featured" class="inline-flex items-center gap-2 bg-white text-primary-800 font-bold px-8 py-3 rounded-xl hover:bg-primary-50 transition text-sm">
          Claim Your Featured Spot →
        </a>
        <p class="text-xs text-primary-300 mt-2">No credit card needed to apply</p>
      </div>
    </div>

    {/* ─── Live Preview Section ────────────────────────────────── */}
    <div class="mb-14" id="preview-section">
      <div class="text-center mb-8">
        <h2 class="text-2xl font-bold text-default mb-2">See exactly what attorneys see</h2>
        <p class="text-muted text-sm">Toggle between a standard and featured listing. Click either card to see the full listing page.</p>
      </div>

      <div class="flex justify-center gap-2 mb-6">
        <button id="tab-standard" class="preview-tab px-4 py-2 rounded-lg text-sm font-semibold border border-gray-300 text-gray-600 hover:border-primary-400 hover:text-primary-700 transition" data-tab="standard">Without Featured</button>
        <button id="tab-featured" class="preview-tab px-4 py-2 rounded-lg text-sm font-semibold border-2 border-primary-500 bg-primary-50 text-primary-700 transition" data-tab="featured">⭐ With Featured ($79/mo)</button>
      </div>

      <div class="relative max-w-2xl mx-auto">

        {/* Standard card */}
        <div id="preview-standard" class="hidden">
          <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden cursor-pointer hover:shadow-md transition group" onclick="openLightbox('standard')">
            <div class="p-5">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <h3 class="font-bold text-gray-900 text-lg leading-tight">Elliott Reporting</h3>
                  <p class="text-sm text-gray-500 mt-0.5">Colorado Springs, CO</p>
                </div>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">No badge</span>
              </div>
              <p class="text-sm text-gray-600 mt-3 line-clamp-2">Full-service reporting firm offering court reporter services, legal videography, and video conferencing in Colorado Springs.</p>
              <div class="flex flex-wrap gap-1.5 mt-3">
                <span class="text-xs bg-gray-50 border border-gray-200 text-gray-600 px-2 py-0.5 rounded-full">Legal Videography</span>
                <span class="text-xs bg-gray-50 border border-gray-200 text-gray-600 px-2 py-0.5 rounded-full">Court Reporting</span>
              </div>
              <div class="mt-4 pt-3 border-t border-gray-100 flex items-center justify-between">
                <span class="text-xs text-gray-400">elliottreporting.com</span>
                <span class="text-xs text-gray-400">Sorted alphabetically · #7 of 12</span>
              </div>
            </div>
            <div class="bg-gray-50 px-5 py-2.5 text-xs text-center text-gray-400">↑ Attorney sees this. Click to see full page →</div>
          </div>
          <p class="text-center text-xs text-red-500 font-medium mt-3">No quote routing · No top placement · Invisible to most attorneys</p>
        </div>

        {/* Featured card */}
        <div id="preview-featured">
          <div class="bg-white rounded-2xl border-2 border-primary-400 shadow-lg overflow-hidden cursor-pointer hover:shadow-xl transition group" onclick="openLightbox('featured')">
            <div class="bg-primary-600 px-5 py-2 flex items-center gap-2">
              <svg class="w-3.5 h-3.5 text-yellow-300" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <span class="text-xs font-bold text-white tracking-wide uppercase">Featured Provider — Pinned #1</span>
            </div>
            <div class="p-5">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <h3 class="font-bold text-gray-900 text-lg leading-tight">Acme Legal Video Services</h3>
                  <p class="text-sm text-gray-500 mt-0.5">Colorado Springs, CO · <span class="text-green-600 font-medium">Open now</span></p>
                </div>
                <div class="flex items-center gap-0.5">
                  {[...Array(5)].map(() => (
                    <svg class="w-3.5 h-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  ))}
                  <span class="text-xs text-gray-500 ml-1">4.9 (28)</span>
                </div>
              </div>
              <p class="text-sm text-gray-600 mt-3 line-clamp-2">CLVS-certified videographer with 15+ years serving litigation attorneys across Colorado. Remote deposition specialists. Same-day availability.</p>
              <div class="flex flex-wrap gap-1.5 mt-3">
                <span class="text-xs bg-accent-50 border border-accent-200 text-accent-700 px-2 py-0.5 rounded-full font-medium">✓ CLVS Certified</span>
                <span class="text-xs bg-gray-50 border border-gray-200 text-gray-600 px-2 py-0.5 rounded-full">Remote Depositions</span>
                <span class="text-xs bg-gray-50 border border-gray-200 text-gray-600 px-2 py-0.5 rounded-full">Same-Day Available</span>
              </div>
              <div class="mt-4 pt-3 border-t border-gray-100 flex items-center justify-between">
                <span class="text-sm font-semibold text-primary-700">📞 (719) 555-0182</span>
                <span class="text-xs text-accent-600 font-semibold group-hover:underline">View listing + Request Quote →</span>
              </div>
            </div>
            <div class="bg-primary-50 px-5 py-2.5 text-xs text-center text-primary-600 font-medium">↑ Attorney sees this first. Click to see full page →</div>
          </div>
          <p class="text-center text-xs text-green-600 font-medium mt-3">Pinned #1 · Quote requests land in your inbox · CLVS badge builds trust</p>
        </div>
      </div>
    </div>

    {/* ─── Lightbox ─────────────────────────────────────────────── */}
    <div id="listing-lightbox" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/60 backdrop-blur-sm" role="dialog" aria-modal="true">
      <div class="relative w-full max-w-3xl max-h-[90vh] overflow-y-auto bg-white rounded-2xl shadow-2xl">
        <button onclick="closeLightbox()" class="absolute top-4 right-4 z-10 w-8 h-8 rounded-full bg-gray-100 hover:bg-gray-200 flex items-center justify-center text-gray-600 transition">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>

        {/* Standard full preview */}
        <div id="lightbox-standard" class="hidden">
          <div class="bg-gray-50 px-6 py-3 border-b border-gray-200 rounded-t-2xl flex items-center gap-3">
            <div class="flex gap-1.5"><div class="w-3 h-3 rounded-full bg-red-400"></div><div class="w-3 h-3 rounded-full bg-yellow-400"></div><div class="w-3 h-3 rounded-full bg-green-400"></div></div>
            <p class="text-xs text-gray-400 font-mono flex-1 text-center">depohire.com/listing/elliott-reporting-colorado-springs/</p>
          </div>
          <div class="p-6">
            <nav class="text-xs text-gray-400 mb-4">Home › Colorado Springs › <span class="text-gray-600">Elliott Reporting</span></nav>
            <div class="flex items-start gap-4 mb-6">
              <div class="w-14 h-14 rounded-xl bg-gray-100 flex items-center justify-center text-gray-400 font-bold text-xl flex-shrink-0">E</div>
              <div class="flex-1">
                <h2 class="text-xl font-bold text-gray-900">Elliott Reporting</h2>
                <p class="text-sm text-gray-500">Colorado Springs, CO</p>
                <div class="flex gap-2 mt-2">
                  <a href="#" class="text-xs border border-gray-300 rounded-lg px-3 py-1 text-gray-600">Visit Website</a>
                </div>
              </div>
            </div>
            <div class="bg-gray-50 rounded-xl p-4 mb-5">
              <h3 class="text-sm font-semibold text-gray-700 mb-1">About</h3>
              <p class="text-sm text-gray-600">Full-service reporting firm offering court reporter services, legal videography, and video conferencing in Colorado Springs.</p>
            </div>
            <div class="mb-5">
              <h3 class="text-sm font-semibold text-gray-700 mb-2">Services</h3>
              <div class="flex flex-wrap gap-1.5">
                <span class="text-xs bg-gray-100 text-gray-600 px-2.5 py-1 rounded-full">Legal Videography</span>
                <span class="text-xs bg-gray-100 text-gray-600 px-2.5 py-1 rounded-full">Court Reporting</span>
                <span class="text-xs bg-gray-100 text-gray-600 px-2.5 py-1 rounded-full">Video Conferencing</span>
              </div>
            </div>
            <div class="rounded-xl border border-gray-200 p-5">
              <h3 class="text-sm font-semibold text-gray-900 mb-3">Request a Quote from Elliott Reporting</h3>
              <div class="space-y-2.5">
                <input class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-400 bg-gray-50" placeholder="Your Name" disabled />
                <input class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm text-gray-400 bg-gray-50" placeholder="Email Address" disabled />
                <button class="w-full bg-primary-600 text-white rounded-lg py-2 text-sm font-semibold opacity-70 cursor-not-allowed">Send Request to Elliott Reporting</button>
              </div>
              <p class="text-xs text-amber-600 mt-2 text-center">⚠️ Lead goes to DepoHire — not to Elliott Reporting's inbox</p>
            </div>
            <div class="mt-6 rounded-xl border border-dashed border-gray-300 p-4 text-center">
              <p class="text-xs text-gray-400">Is this your business? <a href="/advertise/" class="text-primary-600 underline">Claim this listing</a></p>
            </div>
          </div>
          <div class="border-t border-gray-100 bg-amber-50 px-6 py-4">
            <p class="text-sm text-amber-800 font-medium text-center">👆 This is what a standard listing looks like. <a href="/advertise/?plan=featured" class="underline font-bold">Get Featured for $79/mo →</a></p>
          </div>
        </div>

        {/* Featured full preview */}
        <div id="lightbox-featured" class="hidden">
          <div class="bg-gray-50 px-6 py-3 border-b border-gray-200 rounded-t-2xl flex items-center gap-3">
            <div class="flex gap-1.5"><div class="w-3 h-3 rounded-full bg-red-400"></div><div class="w-3 h-3 rounded-full bg-yellow-400"></div><div class="w-3 h-3 rounded-full bg-green-400"></div></div>
            <p class="text-xs text-gray-400 font-mono flex-1 text-center">depohire.com/listing/acme-legal-video-colorado-springs/</p>
          </div>
          <div class="p-6">
            <nav class="text-xs text-gray-400 mb-4">Home › Colorado Springs › <span class="text-gray-600">Acme Legal Video Services</span></nav>
            <div class="flex items-start gap-4 mb-5">
              <div class="w-14 h-14 rounded-xl bg-primary-100 flex items-center justify-center text-primary-600 font-bold text-xl flex-shrink-0">A</div>
              <div class="flex-1">
                <div class="flex items-center gap-2 flex-wrap">
