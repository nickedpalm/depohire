---
import PageLayout from '~/layouts/PageLayout.astro';
import Breadcrumbs from '~/components/directory/Breadcrumbs.astro';
import ListingDetail from '~/components/directory/ListingDetail.astro';
import QuoteForm from '~/components/directory/QuoteForm.astro';
import ListingCard from '~/components/directory/ListingCard.astro';
import config from '~/config';
import citiesData from '~/data/cities.json';
import { getAllListings } from '~/lib/listings';

export async function getStaticPaths() {
  const listings = getAllListings();
  return listings.map(listing => ({
    params: { slug: listing.slug },
    props: { listing },
  }));
}

const { listing } = Astro.props;
const cityInfo = citiesData.find(c => c.slug === listing.city);

// Other providers in this city for comparison — exclude current listing
const allListings = getAllListings();
const otherProviders = allListings
  .filter(l => l.city === listing.city && l.slug !== listing.slug)
  .sort((a, b) => (b.featured ? 1 : 0) - (a.featured ? 1 : 0) || (b.rating || 0) - (a.rating || 0))
  .slice(0, 2);

const title = `${listing.name} — ${config.primaryKeyword} in ${cityInfo?.city || listing.city}, ${listing.state}`;
const description = listing.description || `${listing.name} is a ${config.primaryKeyword} in ${cityInfo?.city || listing.city}, ${listing.state}.`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: listing.name,
  description: listing.description,
  address: {
    '@type': 'PostalAddress',
    streetAddress: listing.address,
    addressLocality: cityInfo?.city,
    addressRegion: listing.state,
  },
  telephone: listing.phone,
  url: listing.website,
  ...(listing.website ? { sameAs: [listing.website] } : {}),
  geo: {
    '@type': 'GeoCoordinates',
    latitude: listing.lat,
    longitude: listing.lng,
  },
  areaServed: {
    '@type': 'City',
    name: cityInfo?.city || listing.city,
  },
  ...(config.jobValue ? { priceRange: config.jobValue } : {}),
  ...(listing.certifications?.length ? {
    hasCredential: listing.certifications.map(c => ({
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'Professional Certification',
      name: c,
    })),
  } : {}),
  ...(listing.review_count > 0 ? {
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: listing.rating,
      reviewCount: listing.review_count,
    },
  } : {}),
};

const metadata = { title, description };
---
<PageLayout metadata={metadata}>
  <Fragment slot="announcement"><span></span></Fragment>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8" data-pagefind-body>

    {/* ─── Back link ────────────────────────────────────────── */}
    <a href={`/${listing.city}/`} class="inline-flex items-center gap-1.5 text-sm text-muted hover:text-accent-600 transition mb-3">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
      All {config.primaryKeyword}s in {cityInfo?.city || listing.city}
    </a>

    <Breadcrumbs crumbs={[
      { label: cityInfo?.stateName || listing.state, href: `/states/${cityInfo?.stateSlug || 'all'}/` },
      { label: cityInfo?.city || listing.city, href: `/${listing.city}/` },
      { label: listing.name },
    ]} />

    {/* ─── Trust signals — surfaced ABOVE the bio ───────────── */}
    {(listing.certifications?.length || listing.years_experience) && (
      <div class="flex flex-wrap gap-2 mb-5 mt-2">
        {listing.certifications?.map(cert => (
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-green-50 border border-green-200 text-xs font-semibold text-green-800">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            {cert}
          </span>
        ))}
        {listing.years_experience && (
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-blue-50 border border-blue-200 text-xs font-semibold text-blue-700">
            {listing.years_experience}+ Years Experience
          </span>
        )}
        {listing.featured && (
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-primary-50 border border-primary-300 text-xs font-semibold text-primary-700">
            <svg class="w-3.5 h-3.5 text-yellow-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            Featured Provider
          </span>
        )}
      </div>
    )}

    {/* ─── Provider header + details ────────────────────────── */}
    <ListingDetail listing={listing} />

    {/* ─── Quote form — primary conversion ─────────────────── */}
    <div class="mt-8" id="quote">
      <div class="mb-3">
        <p class="text-xs text-muted">
          Your request goes directly to {listing.name}. Most featured providers respond within 4 business hours.
        </p>
      </div>
      <QuoteForm
        city={cityInfo?.city || listing.city}
        state={listing.state}
        listingName={listing.name}
        listingSlug={listing.slug}
        providerEmail={listing.email || ''}
        mode="listing"
      />
    </div>

    {/* ─── Other providers in city ──────────────────────────── */}
    {otherProviders.length > 0 && (
      <div class="mt-12">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-bold text-lg text-default">Also serving {cityInfo?.city || listing.city}</h2>
          <a href={`/${listing.city}/`} class="text-sm text-accent-600 hover:underline font-medium">
            View all →
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {otherProviders.map(other => (
            <ListingCard
              slug={other.slug}
              name={other.name}
              city={other.city}
              state={other.state}
              rating={other.rating}
              review_count={other.review_count}
              phone={other.phone}
              certifications={other.certifications}
              services={other.services}
              description={other.description}
              sentiment={other.sentiment}
              featured={other.featured}
            />
          ))}
        </div>
      </div>
    )}

    {/* ─── Back link (bottom) ───────────────────────────────── */}
    <div class="mt-10 pt-6 border-t border-gray-100">
      <a href={`/${listing.city}/`} class="inline-flex items-center gap-1.5 text-sm text-muted hover:text-accent-600 transition">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
        Back to all {config.primaryKeyword}s in {cityInfo?.city || listing.city}
      </a>
    </div>

  </div>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</PageLayout>
