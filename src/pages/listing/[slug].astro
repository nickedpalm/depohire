---
import PageLayout from '~/layouts/PageLayout.astro';
import Breadcrumbs from '~/components/directory/Breadcrumbs.astro';
import ListingDetail from '~/components/directory/ListingDetail.astro';
import QuoteForm from '~/components/directory/QuoteForm.astro';
import AdSlot from '~/components/directory/AdSlot.astro';
import config from '~/config';
import citiesData from '~/data/cities.json';
import { getAllListings } from '~/lib/listings';

export async function getStaticPaths() {
  const listings = getAllListings();
  return listings.map(listing => ({
    params: { slug: listing.slug },
    props: { listing },
  }));
}

const { listing } = Astro.props;
const cityInfo = citiesData.find(c => c.slug === listing.city);
const title = `${listing.name} — ${config.primaryKeyword} in ${cityInfo?.city || listing.city}, ${listing.state}`;
const description = listing.description || `${listing.name} is a ${config.primaryKeyword} in ${cityInfo?.city || listing.city}, ${listing.state}.`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: listing.name,
  description: listing.description,
  address: {
    '@type': 'PostalAddress',
    streetAddress: listing.address,
    addressLocality: cityInfo?.city,
    addressRegion: listing.state,
  },
  telephone: listing.phone,
  url: listing.website,
  ...(listing.website ? { sameAs: [listing.website] } : {}),
  geo: {
    '@type': 'GeoCoordinates',
    latitude: listing.lat,
    longitude: listing.lng,
  },
  areaServed: {
    '@type': 'City',
    name: cityInfo?.city || listing.city,
  },
  ...(config.jobValue ? { priceRange: config.jobValue } : {}),
  ...(listing.certifications?.length ? {
    hasCredential: listing.certifications.map(c => ({
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'Professional Certification',
      name: c,
    })),
  } : {}),
  ...(listing.review_count > 0 ? {
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: listing.rating,
      reviewCount: listing.review_count,
    },
  } : {}),
};

const metadata = { title, description };
---
<PageLayout metadata={metadata}>
  <Fragment slot="announcement"><span></span></Fragment>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8" data-pagefind-body>
    <Breadcrumbs crumbs={[
      { label: cityInfo?.stateName || listing.state, href: `/states/${cityInfo?.stateSlug || 'all'}/` },
      { label: cityInfo?.city || listing.city, href: `/${listing.city}/` },
      { label: listing.name },
    ]} />

    {/* Provider header + details */}
    <ListingDetail listing={listing} />

    {/* Trust signals bar — certifications + sentiment pulled up above the form */}
    {(listing.certifications?.length || listing.sentiment) && (
      <div class="mt-6 mb-2 flex flex-wrap items-center gap-3 p-4 bg-gray-50 rounded-xl border border-gray-100">
        {listing.certifications?.length && (
          <div class="flex flex-wrap gap-2 items-center">
            <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Certified:</span>
            {listing.certifications.map(cert => (
              <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-md text-xs font-semibold bg-green-100 text-green-800">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                {cert}
              </span>
            ))}
          </div>
        )}
        {listing.sentiment && (
          <div class="flex items-center gap-2 ml-auto">
            <span class="text-xs text-gray-500">Client sentiment:</span>
            <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${
              listing.sentiment.score >= 0.7 ? 'bg-green-100 text-green-800' :
              listing.sentiment.score >= 0.4 ? 'bg-yellow-100 text-yellow-800' :
              'bg-red-100 text-red-800'
            }`}>
              {listing.sentiment.label}
            </span>
          </div>
        )}
      </div>
    )}

    {/* Quote form — primary conversion action */}
    <div class="mt-6">
      <QuoteForm
        city={cityInfo?.city || listing.city}
        state={listing.state}
        listingName={listing.name}
        listingSlug={listing.slug}
        mode="listing"
      />
    </div>

    {/* Featured listing ad slot — reframed as provider opportunity */}
    <div class="mt-8">
      <AdSlot placement="listing-bottom" city={cityInfo?.city} state={listing.state} />
    </div>

    {/* Claim banner — lowest priority, attorneys don't need to see this */}
    {!listing.claimed && (
      <div class="mt-6 p-4 rounded-xl border border-dashed border-gray-200 text-center">
        <p class="text-sm text-gray-500">
          Is this your business?{' '}
          <a href="/advertise/" class="text-accent-600 hover:underline font-medium">Claim this listing</a>
          {' '}to update your info and respond to reviews.
        </p>
      </div>
    )}
  </div>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</PageLayout>
