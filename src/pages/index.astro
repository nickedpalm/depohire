---
import PageLayout from '~/layouts/PageLayout.astro';
import SearchBar from '~/components/directory/SearchBar.astro';
import CityGrid from '~/components/directory/CityGrid.astro';
import StateList from '~/components/directory/StateList.astro';
import ListingCard from '~/components/directory/ListingCard.astro';
import config from '~/config';
import citiesData from '~/data/cities.json';
import { getListingCountByCity, getListingCountByState, getAllListings } from '~/lib/listings';

const cityCounts = getListingCountByCity();
const stateCounts = getListingCountByState();
const allListings = getAllListings();
const totalListings = allListings.length;
const totalCities = Object.keys(cityCounts).length;
const totalStates = Object.keys(stateCounts).length;

// Top 6 highest-rated listings with reviews
const featuredPros = allListings
  .filter(l => l.review_count > 0 && l.rating >= 4)
  .sort((a, b) => b.rating - a.rating || b.review_count - a.review_count)
  .slice(0, 6);

// Cities with listings first, then by population
const citiesWithCounts = citiesData
  .map(c => ({ ...c, listingCount: cityCounts[c.slug] || 0 }))
  .sort((a, b) => b.listingCount - a.listingCount || b.population - a.population)
  .slice(0, 25);

// Aggregate states
const stateMap = new Map<string, { stateSlug: string; stateName: string; state: string; cityCount: number; listingCount: number }>();
for (const city of citiesData) {
  const existing = stateMap.get(city.state);
  if (existing) {
    existing.cityCount++;
    existing.listingCount += cityCounts[city.slug] || 0;
  } else {
    stateMap.set(city.state, {
      stateSlug: city.stateSlug,
      stateName: city.stateName,
      state: city.state,
      cityCount: 1,
      listingCount: cityCounts[city.slug] || 0,
    });
  }
}
const states = Array.from(stateMap.values()).sort((a, b) => a.stateName.localeCompare(b.stateName));

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: config.name,
  url: config.siteUrl,
  description: config.description,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${config.siteUrl}/search/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};

const metadata = {
  title: config.name,
  ignoreTitleTemplate: true,
  description: config.description,
};
---
<PageLayout metadata={metadata}>
  <Fragment slot="announcement"><span></span></Fragment>
  <SearchBar size="hero" />

  {/* Stakes subhead */}
  <div class="max-w-2xl mx-auto px-4 text-center -mt-4 mb-2">
    <p class="text-sm md:text-base text-muted">
      The wrong hire can compromise your deposition. Find <strong class="text-gray-700">CLVS-certified professionals</strong> in your city — free, no sign-up required.
    </p>
  </div>

  {/* Value Proposition — above-the-fold hero block */}
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-10">
      <h2 class="font-heading font-bold text-3xl md:text-4xl text-gray-900 mb-3">
        Your deposition videographer search just got easier.
      </h2>
      <p class="text-lg text-muted max-w-2xl mx-auto">
        DepoHire is the only directory built specifically for legal professionals who need to find qualified deposition videographers — fast, in any city, with real information about each provider.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      <div class="card p-6">
        <div class="text-3xl mb-3">📍</div>
        <h3 class="font-heading font-semibold text-lg text-gray-900 mb-1">Search by city</h3>
        <p class="text-sm text-muted">We cover 50+ major cities across the US. Find vetted providers in your jurisdiction in seconds.</p>
      </div>
      <div class="card p-6">
        <div class="text-3xl mb-3">⭐</div>
        <h3 class="font-heading font-semibold text-lg text-gray-900 mb-1">See featured providers</h3>
        <p class="text-sm text-muted">Featured listings include full contact info, specializations, and court certification details.</p>
      </div>
      <div class="card p-6">
        <div class="text-3xl mb-3">📋</div>
        <h3 class="font-heading font-semibold text-lg text-gray-900 mb-1">Download our free checklist</h3>
        <p class="text-sm text-muted">The <a href="/downloads/deposition-hiring-checklist.pdf" class="text-accent-600 hover:underline font-medium">Deposition Hiring Checklist</a> covers everything you need to evaluate a videographer before booking.</p>
      </div>
    </div>

    {/* Primary CTA */}
    <div class="text-center mt-10">
      <a href="/search" class="inline-flex items-center gap-2 bg-accent-600 hover:bg-accent-700 text-white font-semibold text-base px-8 py-3.5 rounded-lg shadow-md hover:shadow-lg transition-all">
        Find a Videographer in Your City
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
      </a>
      <p class="text-xs text-muted mt-2">50+ cities · Free to search · No account needed</p>
    </div>
  </div>

  <CityGrid cities={citiesWithCounts} title={`Find ${config.name} Near You`} />

  {/* Featured Professionals */}
  {featuredPros.length > 0 && (
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <h2 class="text-2xl font-heading font-bold text-center mb-6">Featured Professionals</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {featuredPros.map(listing => (
          <ListingCard
            slug={listing.slug}
            name={listing.name}
            city={listing.city}
            state={listing.state}
            rating={listing.rating}
            review_count={listing.review_count}
            phone={listing.phone}
            certifications={listing.certifications}
            services={listing.services}
            description={listing.description}
            sentiment={listing.sentiment}
            featured={listing.featured}
          />
        ))}
      </div>
    </div>
  )}

  <StateList states={states} />

  {/* Trust stats */}
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
      <div class="p-5">
        <p class="text-3xl font-heading font-bold text-accent-600">{totalStates}+</p>
        <p class="text-sm text-muted mt-1">States Covered</p>
      </div>
      <div class="p-5">
        <p class="text-3xl font-heading font-bold text-accent-600">Updated {new Date().getFullYear()}</p>
        <p class="text-sm text-muted mt-1">Data Verified Regularly</p>
      </div>
      <div class="p-5">
        <p class="text-3xl font-heading font-bold text-accent-600">100%</p>
        <p class="text-sm text-muted mt-1">Free to Search</p>
      </div>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</PageLayout>
