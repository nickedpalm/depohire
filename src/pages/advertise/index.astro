---
import PageLayout from '~/layouts/PageLayout.astro';
import Breadcrumbs from '~/components/directory/Breadcrumbs.astro';
import config from '~/config';

const title = `Get More Deposition Clients — Advertise on ${config.name}`;
const description = `Attorneys in your city are searching for a deposition videographer right now. A Featured listing on DepoHire puts you first. Apply in 2 minutes.`;

const metadata = { title, description };

const LISTMONK_URL = import.meta.env.LISTMONK_URL ?? '';
const LIST_UUID    = 'b8c38467-94a1-4e6a-aeb4-c14a72bd11a8';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  description,
  url: `${config.siteUrl}/advertise/`,
};
---

<PageLayout metadata={metadata}>
  <Fragment slot="announcement"><span></span></Fragment>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <Breadcrumbs crumbs={[{ label: 'For Providers' }]} />

    {/* ─── Hero ─────────────────────────────────────────────── */}
    <div class="bg-gradient-to-br from-primary-900 to-primary-700 rounded-2xl px-8 py-12 text-white mb-6 text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-primary-300 mb-3">For Deposition Videographers</p>
      <h1 class="text-3xl sm:text-4xl font-bold leading-tight mb-4">
        Attorneys in your city are searching<br class="hidden sm:block" /> for a videographer <em class="not-italic text-sky-300">right now.</em>
      </h1>
      <p class="text-lg text-primary-100 max-w-2xl mx-auto">
        Without a Featured listing, they find your competitor first. DepoHire puts you at the top of results in your city — with quote requests routed directly to your inbox.
      </p>
    </div>

    {/* ─── Scarcity callout ─────────────────────────────────── */}
    <div class="bg-amber-50 border border-amber-300 rounded-xl px-5 py-3 mb-10 flex items-start gap-3">
      <svg class="w-5 h-5 text-amber-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
      <p class="text-sm text-amber-800"><strong>Limited availability:</strong> We cap Featured listings at 2–3 per city to protect the value of each placement. If your city is full, you'll be added to the waitlist.</p>
    </div>

    {/* ─── Stats strip ──────────────────────────────────────── */}
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-12">
      {[
        { num: '50+', label: 'Cities covered' },
        { num: '1,000+', label: 'Monthly attorney searches' },
        { num: '2–3', label: 'Featured slots per city max' },
        { num: '$0', label: 'Setup fees, ever' },
      ].map(({ num, label }) => (
        <div class="text-center bg-white rounded-xl border border-gray-100 shadow-sm p-5">
          <p class="text-3xl font-bold text-primary-700">{num}</p>
          <p class="text-sm text-muted mt-1">{label}</p>
        </div>
      ))}
    </div>

    {/* ─── Two-column: packages + form ─────────────────────── */}
    <div class="lg:grid lg:grid-cols-2 lg:gap-12">

      {/* Left: packages */}
      <div>
        <h2 class="text-2xl font-bold text-default mb-6">Placement Options</h2>

        <div class="space-y-5">

          {/* Featured listing */}
          <div class="rounded-xl border-2 border-primary-500 bg-primary-50 p-6">
            <div class="flex items-start justify-between gap-3 mb-1">
              <h3 class="font-bold text-default text-lg">Featured City Listing</h3>
              <span class="flex-shrink-0 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-primary-600 text-white">Most Popular</span>
            </div>
            <p class="text-2xl font-extrabold text-primary-700 mb-1">$79<span class="text-sm font-medium text-muted">/month</span></p>
            <p class="text-xs text-muted mb-3">One job covers months of listing fees.</p>
            <ul class="space-y-2 text-sm text-default">
              {[
                'Pinned to #1 in your city results',
                '"Featured" badge — visible immediately',
                'Quote requests emailed directly to you',
                'Extended bio + full service list',
                'Direct booking link on your profile',
                'CLVS badge (if applicable)',
                'Monthly impressions report',
              ].map(f => (
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  {f}
                </li>
              ))}
            </ul>
          </div>

          {/* City Pro */}
          <div class="rounded-xl border-2 border-amber-300 bg-amber-50 p-6">
            <div class="flex items-start justify-between gap-3 mb-1">
              <h3 class="font-bold text-default text-lg">City Pro</h3>
              <span class="flex-shrink-0 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-amber-400 text-amber-900">Best Value</span>
            </div>
            <p class="text-2xl font-extrabold text-amber-800 mb-1">$149<span class="text-sm font-medium text-muted">/month</span></p>
            <p class="text-xs text-muted mb-3">Everything in Featured, plus editorial SEO + newsletter.</p>
            <ul class="space-y-2 text-sm text-default">
              {[
                'Everything in Featured',
                'Named in "Best in [City]" guide post',
                'Dofollow backlink to your website',
                'Sponsor slot in monthly attorney email',
                'Priority support & quarterly review',
              ].map(f => (
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  {f}
                </li>
              ))}
            </ul>
          </div>

          {/* À la carte */}
          <div class="rounded-xl border border-gray-200 bg-white p-5">
            <h3 class="font-bold text-default mb-3">À La Carte Add-Ons</h3>
            <div class="space-y-2 text-sm">
              <div class="flex items-center justify-between gap-2">
                <span class="text-default">Additional city</span>
                <span class="font-semibold text-primary-700 flex-shrink-0">$49/mo each</span>
              </div>
              <div class="flex items-center justify-between gap-2">
                <span class="text-default">Newsletter spot (one-time)</span>
                <span class="font-semibold text-primary-700 flex-shrink-0">$99</span>
              </div>
              <div class="flex items-center justify-between gap-2">
                <span class="text-default">City guide mention (one-time)</span>
                <span class="font-semibold text-primary-700 flex-shrink-0">$149</span>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-5 p-4 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-600">
          <strong class="text-default">Quality review:</strong> We evaluate all applicants for professionalism, legal videography experience, and verifiable client history. This protects the trust attorneys place in our directory.
        </div>
        <div class="mt-3 text-center">
          <a href="/pricing/" class="text-sm text-primary-600 hover:underline font-medium">See full pricing & feature comparison →</a>
        </div>
      </div>

      {/* Right: form */}
      <div class="mt-10 lg:mt-0">
        <h2 class="text-2xl font-bold text-default mb-1">Apply for a Featured Listing</h2>
        <p class="text-muted text-sm mb-6">Takes 2 minutes. We'll confirm availability in your city and follow up within one business day.</p>

        <div id="advertise-form" class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6 sm:p-8">
          <div id="form-fields">
            <div class="space-y-4">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label for="adv-name" class="block text-sm font-medium text-default mb-1">Your Name <span class="text-red-500">*</span></label>
                  <input id="adv-name" type="text" placeholder="Jane Smith"
                    class="w-full px-3 py-2.5 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                </div>
                <div>
                  <label for="adv-company" class="block text-sm font-medium text-default mb-1">Business Name <span class="text-red-500">*</span></label>
                  <input id="adv-company" type="text" placeholder="Acme Legal Video"
                    class="w-full px-3 py-2.5 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                </div>
              </div>

              <div>
                <label for="adv-email" class="block text-sm font-medium text-default mb-1">Email Address <span class="text-red-500">*</span></label>
                <input id="adv-email" type="email" placeholder="you@yourbusiness.com"
                  class="w-full px-3 py-2.5 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
              </div>

              <div>
                <label for="adv-city" class="block text-sm font-medium text-default mb-1">Primary City / Metro <span class="text-red-500">*</span></label>
                <input id="adv-city" type="text" placeholder="Chicago, IL"
                  class="w-full px-3 py-2.5 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
              </div>

              <div>
                <label for="adv-interest" class="block text-sm font-medium text-default mb-1">Which plan interests you?</label>
                <select id="adv-interest"
                  class="w-full px-3 py-2.5 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent">
                  <option value="">Select a plan...</option>
                  <option value="featured">Featured Listing — $79/mo</option>
                  <option value="citypro">City Pro — $149/mo</option>
                  <option value="guide">City Guide Mention — $149 one-time</option>
                  <option value="newsletter">Newsletter Sponsorship — $99/send</option>
                  <option value="multiple">Multiple / Not sure yet</option>
                </select>
              </div>

              <div>
                <label for="adv-message" class="block text-sm font-medium text-default mb-1">Anything else? <span class="text-muted font-normal">(optional)</span></label>
                <textarea id="adv-message" rows="3"
                  placeholder="Certification, specialization, coverage area, multiple cities..."
                  class="w-full px-3 py-2.5 rounded-lg border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent resize-none"></textarea>
              </div>

              <p id="form-error" class="hidden text-sm text-red-600"></p>

              <button id="adv-submit" type="button"
                class="w-full btn-primary py-3 font-bold text-sm rounded-lg flex items-center justify-center gap-2">
                <span id="btn-label">Apply for a Featured Listing →</span>
                <svg id="btn-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"></path>
                </svg>
              </button>

              <p class="text-xs text-center text-muted">
                No credit card needed · Goes live in 2–3 business days · Cancel anytime
              </p>
            </div>
          </div>

          <div id="form-success" class="hidden text-center py-6">
            <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-default mb-2">Application received!</h3>
            <p class="text-muted text-sm">We'll confirm availability in your city and follow up within one business day with next steps.</p>
          </div>
        </div>
      </div>
    </div>

    {/* ─── ROI block ────────────────────────────────────────── */}
    <div class="mt-16 bg-gradient-to-br from-primary-900 to-primary-700 rounded-2xl p-8 text-white text-center">
      <h2 class="text-xl font-bold mb-2">One job pays for months of listing fees.</h2>
      <p class="text-primary-200 text-sm mb-6 max-w-xl mx-auto">The average deposition session pays $500–2,000. A Featured listing is $79/month. One booked job from DepoHire and you're profitable for the rest of the year.</p>
      <a href="#advertise-form" class="inline-flex items-center gap-2 bg-white text-primary-800 font-bold px-8 py-3 rounded-xl hover:bg-primary-50 transition text-sm">
        Apply Now — It Takes 2 Minutes →
      </a>
    </div>

    {/* ─── FAQ ──────────────────────────────────────────────── */}
    <div class="mt-16">
      <h2 class="text-2xl font-bold text-default mb-6 text-center">Common Questions</h2>
      <div class="grid sm:grid-cols-2 gap-6 max-w-4xl mx-auto">
        {[
          {
            q: 'Will this actually send me clients?',
            a: 'That depends on your city and how competitive you are on price and credibility. What we can say: every quote form submitted on your listing page is emailed directly to you — name, email, case type, and preferred date. You follow up on your own timeline. There\'s no middleman.',
          },
          {
            q: 'Who sees my listing?',
            a: 'Primarily litigation attorneys, paralegals, and legal ops professionals searching for deposition videographers in their city. Traffic is high-intent — people don\'t search "deposition videographer Chicago" unless they\'re about to hire one.',
          },
          {
            q: 'Do I need to be CLVS certified?',
            a: 'Preferred but not required. We evaluate all applicants on professional credentials and a verifiable track record in legal videography. CLVS gets you a visible trust badge on your listing.',
          },
          {
            q: 'How long does setup take?',
            a: 'Featured listings go live within 2–3 business days of approval. We\'ll reach out to collect your bio, services, photo, and booking link before publishing.',
          },
          {
            q: 'Can I advertise in multiple cities?',
            a: 'Yes — each additional city is $49/month on top of your base plan. Regional firms commonly list in 2–3 metros.',
          },
          {
            q: 'Is there a contract or setup fee?',
            a: 'No setup fee. No annual contract. Month-to-month with 30 days notice to cancel. We want you to stay because it\'s working, not because you\'re locked in.',
          },
        ].map(({ q, a }) => (
          <div class="bg-white rounded-xl border border-gray-200 p-5">
            <h3 class="font-semibold text-default mb-2 text-sm">{q}</h3>
            <p class="text-sm text-muted leading-relaxed">{a}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <script define:vars={{ LISTMONK_URL, LIST_UUID }}>
    const submitBtn   = document.getElementById('adv-submit');
    const btnLabel    = document.getElementById('btn-label');
    const btnSpinner  = document.getElementById('btn-spinner');
    const formFields  = document.getElementById('form-fields');
    const formSuccess = document.getElementById('form-success');
    const formError   = document.getElementById('form-error');

    function setLoading(on) {
      submitBtn.disabled = on;
      btnLabel.textContent = on ? 'Sending...' : 'Apply for a Featured Listing →';
      btnSpinner.classList.toggle('hidden', !on);
    }
    function showError(msg) { formError.textContent = msg; formError.classList.remove('hidden'); }
    function hideError()    { formError.classList.add('hidden'); }

    submitBtn.addEventListener('click', async () => {
      hideError();
      const name     = document.getElementById('adv-name').value.trim();
      const company  = document.getElementById('adv-company').value.trim();
      const email    = document.getElementById('adv-email').value.trim();
      const city     = document.getElementById('adv-city').value.trim();
      const interest = document.getElementById('adv-interest').value;
      const message  = document.getElementById('adv-message').value.trim();

      if (!name)    { showError('Please enter your name.'); return; }
      if (!company) { showError('Please enter your business name.'); return; }
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { showError('Please enter a valid email address.'); return; }
      if (!city)    { showError('Please enter your primary city.'); return; }

      setLoading(true);
      try {
        const response = await fetch('/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, name, source: 'advertise-form' }),
        });
        if (response.ok) {
          window.location.href = '/advertise/success/';
        } else {
          showError('Something went wrong. Please try again or email us directly.');
        }
      } catch (err) {
        showError('Network error. Please check your connection and try again.');
      } finally {
        setLoading(false);
      }
    });
  </script>

  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</PageLayout>
