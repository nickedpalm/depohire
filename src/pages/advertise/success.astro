---
/**
 * FILE LOCATION: src/pages/advertise/success.astro
 * Post-submission confirmation for the advertise/provider interest form.
 */
import PageLayout from '~/layouts/PageLayout.astro';
import config from '~/config';

const metadata = {
  title: `Application Received — ${config.name}`,
  description: "Your Featured listing application has been received. Here's what happens next.",
  robots: 'noindex',
};
---

<PageLayout metadata={metadata}>
  <Fragment slot="announcement"><span></span></Fragment>

  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">

    {/* ─── Check icon ─── */}
    <div class="w-20 h-20 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-6">
      <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
      </svg>
    </div>

    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-3">
      Application received!
    </h1>
    <p class="text-lg text-muted mb-12 max-w-lg mx-auto">
      We'll confirm availability in your city and follow up within one business day.
    </p>

    {/* ─── What happens next ─── */}
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8 text-left mb-10">
      <h2 class="text-lg font-bold text-gray-900 mb-6">Here's what happens next</h2>

      <ol class="space-y-6">
        <li class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary-100 text-primary-700 flex items-center justify-center text-sm font-bold">1</div>
          <div>
            <p class="font-semibold text-gray-900 text-sm">We check availability in your city</p>
            <p class="text-sm text-muted mt-0.5">Featured slots are capped at 2–3 per city. We'll confirm whether a slot is open for you — usually within a few hours.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary-100 text-primary-700 flex items-center justify-center text-sm font-bold">2</div>
          <div>
            <p class="font-semibold text-gray-900 text-sm">We send you a setup email</p>
            <p class="text-sm text-muted mt-0.5">You'll get a link to review your listing draft, confirm your details, and complete setup. No credit card until you approve the listing.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary-100 text-primary-700 flex items-center justify-center text-sm font-bold">3</div>
          <div>
            <p class="font-semibold text-gray-900 text-sm">Your listing goes live in 2–3 business days</p>
            <p class="text-sm text-muted mt-0.5">Once confirmed, your Featured listing pins to the top of your city page. Attorney quote requests go directly to your inbox — name, email, case type, and date.</p>
          </div>
        </li>
      </ol>
    </div>

    {/* ─── Check spam nudge ─── */}
    <div class="rounded-xl bg-amber-50 border border-amber-200 p-5 text-left mb-10">
      <div class="flex gap-3">
        <svg class="w-5 h-5 text-amber-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <p class="text-sm text-amber-800">
          <strong>Check your inbox</strong> — our follow-up comes from <strong>contact@depohire.com</strong>.
          If you don't see it within 24 hours, check your spam folder or <a href="mailto:contact@depohire.com" class="underline hover:text-amber-900">email us directly</a>.
        </p>
      </div>
    </div>

    {/* ─── Browse CTA ─── */}
    <p class="text-sm text-muted mb-4">In the meantime, see how your listing will appear to attorneys:</p>
    <a href="/" class="inline-flex items-center gap-2 btn-primary px-6 py-2.5 text-sm font-semibold">
      Browse the directory →
    </a>

  </div>
</PageLayout>
