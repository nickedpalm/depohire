---
import PageLayout from '~/layouts/PageLayout.astro';
import Breadcrumbs from '~/components/directory/Breadcrumbs.astro';
import ListingCard from '~/components/directory/ListingCard.astro';
import LeafletMap from '~/components/directory/LeafletMap.astro';
import AdSlot from '~/components/directory/AdSlot.astro';
import FAQAccordion from '~/components/directory/FAQAccordion.astro';
import RelatedContent from '~/components/directory/RelatedContent.astro';
import config from '~/config';
import citiesData from '~/data/cities.json';
import { getListingsForCity } from '~/lib/listings';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const cityContent = await getCollection('cities');
  return citiesData.map(city => {
    const content = cityContent.find(c => c.data.slug === city.slug);
    return {
      params: { city: city.slug },
      props: { cityInfo: city, content },
    };
  });
}

const { cityInfo, content } = Astro.props;
const allListings = getListingsForCity(cityInfo.slug);
const { Content } = content ? await render(content) : { Content: null };
const heroImage = content?.data?.image;
const imageCredit = content?.data?.imageCredit;

const featured = allListings.filter(l => l.featured);
const regular = allListings.filter(l => !l.featured).sort((a, b) => (b.rating || 0) - (a.rating || 0));
const listings = [...featured, ...regular];
const firstFeatured = featured[0];

const currentYear = new Date().getFullYear();
// SEO title stays keyword-rich — but H1 will be conversational
const seoTitle = `Best ${config.primaryKeyword}s in ${cityInfo.city}, ${cityInfo.state} (${currentYear})`;
const metaDescription = `Find the best ${config.primaryKeyword}s in ${cityInfo.city}, ${cityInfo.state}. Compare ${listings.length} verified professionals, see certifications, and request quotes. Updated ${currentYear}.`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: seoTitle,
  description: metaDescription,
  numberOfItems: listings.length,
  itemListElement: listings.map((l, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'LocalBusiness',
      name: l.name,
      address: l.address,
      telephone: l.phone,
      url: `${config.siteUrl}/listing/${l.slug}/`,
      aggregateRating: l.review_count > 0 ? {
        '@type': 'AggregateRating',
        ratingValue: l.rating,
        reviewCount: l.review_count,
      } : undefined,
    },
  })),
};

const metadata = { title: seoTitle, description: metaDescription };
---
<PageLayout metadata={metadata}>
  <Fragment slot="announcement"><span></span></Fragment>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs crumbs={[
      { label: cityInfo.stateName || cityInfo.state, href: `/states/${cityInfo.stateSlug}/` },
      { label: cityInfo.city },
    ]} />

    {heroImage && (
      <div class="relative rounded-xl overflow-hidden mb-6 -mx-4 sm:mx-0">
        <img
          src={heroImage}
          alt={`${cityInfo.city}, ${cityInfo.state} skyline`}
          class="w-full h-48 sm:h-64 md:h-80 object-cover"
          loading="eager"
          decoding="async"
        />
        {imageCredit && (
          <p class="absolute bottom-2 right-3 text-[10px] text-white/80 bg-black/40 px-2 py-0.5 rounded" set:html={imageCredit.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="underline hover:text-white" target="_blank" rel="noopener noreferrer">$1</a>')} />
        )}
      </div>
    )}

    {/* ─── Real headline (not the SEO title) ───────────────── */}
    <h1 class="text-3xl font-bold text-default mb-2">
      Hiring a deposition videographer in {cityInfo.city}?
    </h1>
    <p class="text-muted text-base mb-6 max-w-2xl">
      Here are {listings.length} verified provider{listings.length !== 1 ? 's' : ''} serving {cityInfo.city}, {cityInfo.stateName}. Check credentials, read reviews, and submit a quote request directly — no phone tag required.
    </p>

    {/* ─── Social proof bar ────────────────────────────────── */}
    <div class="flex flex-wrap items-center gap-x-5 gap-y-2 mb-6 text-sm text-muted">
      <span class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-600"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <strong class="font-semibold text-default">{listings.length}</strong> verified provider{listings.length !== 1 ? 's' : ''}
      </span>
      {featured.length > 0 && (
        <span class="flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" class="text-amber-400"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <strong class="font-semibold text-default">{featured.length}</strong> featured
        </span>
      )}
      <span class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-500"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Verified listings
      </span>
      <span class="flex items-center gap-1.5 ml-auto text-xs">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Updated {new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
      </span>
    </div>

    {/* ─── Why local matters — reframed as attorney guidance ── */}
    <div class="grid grid-cols-3 gap-3 mb-8">
      <div class="bg-red-50 border border-red-100 rounded-xl p-4 text-center">
        <p class="text-2xl font-bold text-red-700 font-heading">$100–300</p>
        <p class="text-xs text-red-600 mt-1 leading-tight">extra your client pays when an out-of-market provider travels to {cityInfo.city}</p>
      </div>
      <div class="bg-green-50 border border-green-100 rounded-xl p-4 text-center">
        <p class="text-2xl font-bold text-green-700 font-heading">2–3×</p>
        <p class="text-xs text-green-600 mt-1 leading-tight">faster booking turnaround with a local provider vs. out-of-market</p>
      </div>
      <div class="bg-amber-50 border border-amber-100 rounded-xl p-4 text-center">
        <p class="text-2xl font-bold text-amber-700 font-heading">CLVS</p>
        <p class="text-xs text-amber-600 mt-1 leading-tight">the NCRA gold standard — look for this badge before you book</p>
      </div>
    </div>

    {/* ─── Listings ─────────────────────────────────────────── */}
    {listings.length > 0 ? (
      <div data-pagefind-body>
        {featured.length > 0 && (
          <div class="grid grid-cols-1 gap-4 mb-4">
            {featured.map(listing => (
              <ListingCard {...listing} />
            ))}
          </div>
        )}

        {listings.length >= 3 && (
          <div class="mb-4">
            <AdSlot placement="city-top" city={cityInfo.city} state={cityInfo.state} />
          </div>
        )}

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
          {regular.map(listing => (
            <ListingCard {...listing} />
          ))}
        </div>
      </div>
    ) : (
      <div class="text-center py-12 text-muted">
        <p>No {config.primaryKeyword}s listed in {cityInfo.city} yet.</p>
        <p class="mt-2 text-sm">Are you a provider here? <a href="/advertise/" class="text-accent-600 hover:underline font-medium">Get listed →</a></p>
      </div>
    )}

    {Content && (
      <div class="prose prose-lg max-w-none mt-8 [&_blockquote]:not-italic [&_blockquote]:border-l-4 [&_blockquote]:border-accent-400 [&_blockquote]:bg-accent-50 [&_blockquote]:rounded-r-xl [&_blockquote]:px-5 [&_blockquote]:py-4 [&_blockquote]:my-8 [&_blockquote]:text-gray-700 [&_blockquote_strong]:text-accent-700 [&_blockquote_strong]:block [&_blockquote_strong]:mb-1 [&_blockquote_strong]:text-sm [&_blockquote_strong]:uppercase [&_blockquote_strong]:tracking-wide">
        <Content />
      </div>
    )}

    {/* ─── Mid-page CTA ─────────────────────────────────────── */}
    <div class="my-10 bg-[#0d2d5e] rounded-2xl px-8 py-8 flex flex-col sm:flex-row items-center justify-between gap-6">
      <div>
        <p class="text-white font-bold text-xl mb-1">Ready to request a quote?</p>
        <p class="text-blue-200 text-sm">Submit directly from any listing — name, case type, and date. No phone tag.</p>
      </div>
      {firstFeatured ? (
        <a
          href={`/listing/${firstFeatured.slug}/#quote`}
          class="flex-shrink-0 inline-flex items-center gap-2 bg-[#0ea5e9] hover:bg-sky-400 text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors"
        >
          Request a Quote
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      ) : (
        <a
          href={`/${cityInfo.slug}/#listings`}
          class="flex-shrink-0 inline-flex items-center gap-2 bg-[#0ea5e9] hover:bg-sky-400 text-white font-semibold text-sm px-6 py-3 rounded-lg transition-colors"
        >
          View All Providers
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
      )}
    </div>

    {/* ─── FAQ — specific and useful ────────────────────────── */}
    <FAQAccordion faqs={[
      {
        question: `How do I know if a videographer in ${cityInfo.city} is qualified?`,
        answer: `Look for CLVS (Certified Legal Video Specialist) certification from NCRA — it's the industry gold standard and requires ongoing education. Beyond that, check for experience in your specific case type, reviews from other attorneys, and whether they have professional-grade equipment. All of this is visible on individual listing pages here.`,
      },
      {
        question: `How much does a deposition videographer cost in ${cityInfo.city}?`,
        answer: `Rates in ${cityInfo.city} typically range from ${config.jobValue} depending on session length, services required (real-time streaming, same-day delivery, video sync), and travel. Always get at least two quotes before booking — use the quote form on any listing to request pricing directly from the provider.`,
      },
      {
        question: `How many verified videographers are there in ${cityInfo.city}?`,
        answer: `We currently list ${listings.length} verified ${config.primaryKeyword}${listings.length !== 1 ? 's' : ''} serving the ${cityInfo.city}, ${cityInfo.stateName} area. Listings are reviewed for accuracy and updated regularly.`,
      },
      {
        question: `What's the difference between a featured and standard listing?`,
        answer: `Featured providers are pinned to the top of results and have passed our quality review. They include extended bios, full service lists, certifications, and direct quote routing. Standard listings show basic contact info. Both are real businesses — featured providers have simply invested in more complete profiles.`,
      },
    ]} />

    <RelatedContent city={cityInfo.city} state={cityInfo.state} citySlug={cityInfo.slug} />

    <p class="text-xs text-muted mt-8">
      Last updated: {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
    </p>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</PageLayout>
