---
import PageLayout from '~/layouts/PageLayout.astro';
import SearchBar from '~/components/directory/SearchBar.astro';
import CityGrid from '~/components/directory/CityGrid.astro';
import StateList from '~/components/directory/StateList.astro';
import ListingCard from '~/components/directory/ListingCard.astro';
import config from '~/config';
import citiesData from '~/data/cities.json';
import { getListingCountByCity, getListingCountByState, getAllListings } from '~/lib/listings';

const cityCounts = getListingCountByCity();
const stateCounts = getListingCountByState();
const allListings = getAllListings();
const totalListings = allListings.length;
const totalCities = Object.keys(cityCounts).length;
const totalStates = Object.keys(stateCounts).length;

// Top 6 highest-rated listings with reviews
const featuredPros = allListings
  .filter(l => l.review_count > 0 && l.rating >= 4)
  .sort((a, b) => b.rating - a.rating || b.review_count - a.review_count)
  .slice(0, 6);

// Cities with listings first, then by population
const citiesWithCounts = citiesData
  .map(c => ({ ...c, listingCount: cityCounts[c.slug] || 0 }))
  .sort((a, b) => b.listingCount - a.listingCount || b.population - a.population)
  .slice(0, 25);

// Aggregate states
const stateMap = new Map<string, { stateSlug: string; stateName: string; state: string; cityCount: number; listingCount: number }>();
for (const city of citiesData) {
  const existing = stateMap.get(city.state);
  if (existing) {
    existing.cityCount++;
    existing.listingCount += cityCounts[city.slug] || 0;
  } else {
    stateMap.set(city.state, {
      stateSlug: city.stateSlug,
      stateName: city.stateName,
      state: city.state,
      cityCount: 1,
      listingCount: cityCounts[city.slug] || 0,
    });
  }
}
const states = Array.from(stateMap.values()).sort((a, b) => a.stateName.localeCompare(b.stateName));

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: config.name,
  url: config.siteUrl,
  description: config.description,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${config.siteUrl}/search/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};

const metadata = {
  title: config.name,
  ignoreTitleTemplate: true,
  description: config.description,
};
---
<PageLayout metadata={metadata}>
  <Fragment slot="announcement"><span></span></Fragment>
  <SearchBar size="hero" />

  {/* Value Proposition — 3-column icon cards */}
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      <div class="card p-6 text-center">
        <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-accent-100 flex items-center justify-center">
          <svg class="w-6 h-6 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <h3 class="font-heading font-semibold text-lg text-gray-900">Verified Listings</h3>
        <p class="text-sm text-muted mt-1">{totalListings.toLocaleString()} professionals with verified contact info and credentials.</p>
      </div>
      <div class="card p-6 text-center">
        <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-accent-100 flex items-center justify-center">
          <svg class="w-6 h-6 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>
        </div>
        <h3 class="font-heading font-semibold text-lg text-gray-900">Real Reviews</h3>
        <p class="text-sm text-muted mt-1">Read authentic client feedback and sentiment analysis before you hire.</p>
      </div>
      <div class="card p-6 text-center">
        <div class="w-12 h-12 mx-auto mb-3 rounded-full bg-accent-100 flex items-center justify-center">
          <svg class="w-6 h-6 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
        </div>
        <h3 class="font-heading font-semibold text-lg text-gray-900">Free Quotes</h3>
        <p class="text-sm text-muted mt-1">Contact professionals directly — no middlemen, no fees, no obligations.</p>
      </div>
    </div>
  </div>

  <CityGrid cities={citiesWithCounts} title={`Find ${config.name} Near You`} />

  {/* Featured Professionals */}
  {featuredPros.length > 0 && (
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <h2 class="text-2xl font-heading font-bold text-center mb-6">Featured Professionals</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {featuredPros.map(listing => (
          <ListingCard
            slug={listing.slug}
            name={listing.name}
            city={listing.city}
            state={listing.state}
            rating={listing.rating}
            review_count={listing.review_count}
            phone={listing.phone}
            certifications={listing.certifications}
            services={listing.services}
            description={listing.description}
            sentiment={listing.sentiment}
            featured={listing.featured}
          />
        ))}
      </div>
    </div>
  )}

  <StateList states={states} />

  {/* Trust stats */}
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
      <div class="p-5">
        <p class="text-3xl font-heading font-bold text-accent-600">{totalStates}+</p>
        <p class="text-sm text-muted mt-1">States Covered</p>
      </div>
      <div class="p-5">
        <p class="text-3xl font-heading font-bold text-accent-600">Updated {new Date().getFullYear()}</p>
        <p class="text-sm text-muted mt-1">Data Verified Regularly</p>
      </div>
      <div class="p-5">
        <p class="text-3xl font-heading font-bold text-accent-600">100%</p>
        <p class="text-sm text-muted mt-1">Free to Search</p>
      </div>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</PageLayout>
