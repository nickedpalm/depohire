---
import PageLayout from '~/layouts/PageLayout.astro';
import config from '~/config';

const metadata = {
  title: `Search | ${config.name}`,
  description: `Search the ${config.name} directory.`,
};
---
<PageLayout metadata={metadata}>
  <Fragment slot="announcement"><span></span></Fragment>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-3xl font-bold text-default mb-6">Search</h1>
    <div id="search" class="min-h-[400px]"></div>
  </div>
  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    function initPagefind() {
      new PagefindUI({
        element: '#search',
        showSubResults: true,
        showImages: false,
      });
      const params = new URLSearchParams(window.location.search);
      const q = params.get('q');
      if (q) {
        const input = document.querySelector('.pagefind-ui__search-input');
        if (input) {
          input.value = q;
          input.dispatchEvent(new Event('input', { bubbles: true }));
        }
      }
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPagefind);
    } else {
      initPagefind();
    }
    document.addEventListener('astro:page-load', initPagefind);
  </script>
</PageLayout>
