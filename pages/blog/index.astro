---
import PageLayout from '~/layouts/PageLayout.astro';
import Breadcrumbs from '~/components/directory/Breadcrumbs.astro';
import config from '~/config';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => (b.data.pubDate?.valueOf() || 0) - (a.data.pubDate?.valueOf() || 0));

const pillar = allPosts.find(p => p.data.tags.includes('pillar'));
const posts = allPosts.filter(p => p !== pillar);

// Heuristic category mapping from tags
function categorize(tags: string[]): string {
  const joined = tags.join(' ').toLowerCase();
  if (joined.includes('equipment') || joined.includes('camera') || joined.includes('tech') || joined.includes('software') || joined.includes('ai')) return 'tech-hardware';
  if (joined.includes('legal') || joined.includes('compliance') || joined.includes('rule') || joined.includes('court') || joined.includes('law')) return 'legal-compliance';
  if (joined.includes('city') || joined.includes('best-in') || joined.includes('houston') || joined.includes('chicago') || joined.includes('los angeles') || joined.includes('new york') || joined.includes('dallas') || joined.includes('miami') || joined.includes('atlanta') || joined.includes('denver') || joined.includes('seattle') || joined.includes('phoenix') || joined.includes('san')) return 'city-guides';
  return 'best-practices';
}

const metadata = {
  title: `Expert Insights | ${config.name}`,
  description: `Articles and guides about ${config.primaryKeyword}s.`,
};
---
<PageLayout metadata={metadata}>
  <Fragment slot="announcement"><span></span></Fragment>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs crumbs={[{ label: 'Expert Insights' }]} />
    <h1 class="text-3xl font-heading font-bold text-default mb-2">Expert Insights</h1>
    <p class="text-muted mb-6">Expert guides and insights on {config.primaryKeyword}s</p>

    {/* Category filter tabs */}
    <div class="flex flex-wrap gap-2 mb-8" id="filter-tabs">
      <button class="filter-btn active" data-filter="all">All</button>
      <button class="filter-btn" data-filter="tech-hardware">Tech & Hardware</button>
      <button class="filter-btn" data-filter="legal-compliance">Legal Compliance</button>
      <button class="filter-btn" data-filter="best-practices">Best Practices</button>
      <button class="filter-btn" data-filter="city-guides">City Guides</button>
    </div>

    {pillar && (
      <a href={`/blog/${pillar.id}/`} data-category="all" class="blog-card block mb-12 rounded-xl border-2 border-accent-100 bg-gradient-to-br from-blue-50 to-accent-50/30 p-8 no-underline group hover:border-accent-200 hover:shadow-lg transition-all">
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-accent-100 text-accent-700 mb-3">Complete Guide</span>
        <h2 class="text-2xl sm:text-3xl font-heading font-bold text-default group-hover:text-accent-600 transition-colors">{pillar.data.title}</h2>
        <p class="text-muted mt-3 text-lg leading-relaxed">{pillar.data.description}</p>
        <span class="inline-flex items-center mt-4 text-accent-600 font-medium text-sm group-hover:gap-2 transition-all">
          Read the complete guide <span class="ml-1">&rarr;</span>
        </span>
      </a>
    )}

    <div class="grid sm:grid-cols-2 gap-4" id="blog-grid">
      {posts.map(post => {
        const category = categorize(post.data.tags);
        return (
          <a href={`/blog/${post.id}/`} data-category={category} class="blog-card card block p-0 no-underline group overflow-hidden">
            {post.data.image && (
              <img src={post.data.image} alt="" class="w-full h-40 object-cover" loading="lazy" />
            )}
            <div class="p-5">
              <h2 class="text-base font-semibold text-default group-hover:text-accent-600 transition-colors leading-snug">{post.data.title}</h2>
              <p class="text-muted mt-1 text-sm">
                {post.data.pubDate?.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </p>
              <p class="text-muted mt-2 text-sm line-clamp-2">{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1 mt-3">
                  {post.data.tags.slice(0, 3).map((tag: string) => (
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-muted">{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </a>
        );
      })}
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tabs = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
      const cards = document.querySelectorAll<HTMLElement>('.blog-card');

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const filter = tab.dataset.filter;
          tabs.forEach(t => t.classList.remove('active'));
          tab.classList.add('active');

          cards.forEach(card => {
            const cat = card.dataset.category;
            if (filter === 'all' || cat === filter || cat === 'all') {
              card.classList.remove('hidden');
            } else {
              card.classList.add('hidden');
            }
          });
        });
      });
    });
  </script>
</PageLayout>
