---
import PageLayout from '~/layouts/PageLayout.astro';
import Breadcrumbs from '~/components/directory/Breadcrumbs.astro';
import AuthorBox from '~/components/directory/AuthorBox.astro';
import RelatedContent from '~/components/directory/RelatedContent.astro';
import config from '~/config';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, author = config.editorialAuthor.name, tags = [], hub, image: heroImage, imageCredit } = post.data;
const formattedDate = pubDate ? pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : '';
const body = post.body || '';
const wordCount = body.split(/\s+/).length;
const readingTime = Math.max(1, Math.round(wordCount / 200));

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate?.toISOString(),
  dateModified: new Date().toISOString(),
  author: {
    '@type': 'Person',
    name: config.editorialAuthor.name,
    jobTitle: config.editorialAuthor.title,
    ...(config.editorialAuthor.linkedin ? { sameAs: [config.editorialAuthor.linkedin] } : {}),
    knowsAbout: [config.primaryKeyword, config.industry, ...config.secondaryKeywords.slice(0, 3)],
  },
  publisher: {
    '@type': 'Organization',
    name: config.name,
    url: config.siteUrl,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${config.siteUrl}/blog/`,
  },
};

const metadata = { title, description };
---
<PageLayout metadata={metadata}>
  <Fragment slot="announcement"><span></span></Fragment>
  <section class="py-8 sm:py-16 lg:py-20 mx-auto">
    <article>
      <header class="intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
        <div class="max-w-3xl mx-auto px-4 sm:px-6">
          <Breadcrumbs crumbs={[
            { label: 'Blog', href: '/blog/' },
            ...(hub ? [{ label: hub, href: `/blog/${hub.toLowerCase().replace(/\s+/g, '-')}/` }] : []),
            { label: title },
          ]} />
        </div>

        <div class="flex justify-between flex-col sm:flex-row max-w-3xl mx-auto mt-0 mb-2 px-4 sm:px-6 sm:items-center">
          <p class="text-sm text-muted">
            <svg class="w-4 h-4 inline-block -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <time datetime={pubDate?.toISOString()}>{formattedDate}</time>
            {' '}&middot;{' '}
            <svg class="w-4 h-4 inline-block -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
            <a href="/about/" class="hover:underline inline-block">{author}</a>
            {' '}&middot; <span>{readingTime} min read</span>
          </p>
        </div>

        <h1 class="px-4 sm:px-6 max-w-3xl mx-auto text-4xl md:text-5xl font-bold leading-tighter tracking-tighter font-heading">
          {title}
        </h1>

        <p class="max-w-3xl mx-auto mt-4 mb-8 px-4 sm:px-6 text-xl md:text-2xl text-muted">
          {description}
        </p>

        {tags.length > 0 && (
          <div class="max-w-3xl mx-auto px-4 sm:px-6 mb-6">
            <div class="flex flex-wrap gap-1.5">
              {tags.map((tag) => (
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700">{tag}</span>
              ))}
            </div>
          </div>
        )}

        <div class="max-w-3xl mx-auto px-4 sm:px-6">
          {heroImage ? (
            <div class="relative rounded-xl overflow-hidden">
              <img
                src={heroImage}
                alt={title}
                class="w-full h-48 sm:h-64 md:h-80 object-cover"
                loading="eager"
                decoding="async"
              />
              {imageCredit && (
                <p class="absolute bottom-2 right-3 text-[10px] text-white/80 bg-black/40 px-2 py-0.5 rounded" set:html={imageCredit.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="underline hover:text-white" target="_blank" rel="noopener noreferrer">$1</a>')} />
              )}
            </div>
          ) : (
            <div class="border-t border-gray-200"></div>
          )}
        </div>
      </header>

      <div
        class="mx-auto px-4 sm:px-6 max-w-3xl prose prose-lg lg:prose-xl prose-headings:font-heading prose-headings:font-bold prose-headings:leading-tighter prose-headings:tracking-tighter prose-a:text-primary prose-a:no-underline hover:prose-a:underline prose-img:rounded-md prose-img:shadow-lg prose-headings:scroll-mt-[80px] prose-li:my-0 mt-8"
        id="article-content"
      >
        <Content />
      </div>

      <div class="mx-auto px-4 sm:px-6 max-w-3xl">
        <AuthorBox />
        <RelatedContent currentSlug={Astro.url.pathname} />
      </div>

      <p class="text-xs text-muted mt-6 max-w-3xl mx-auto px-4 sm:px-6">
        Last updated: {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
    </article>
  </section>

  <script>
    function enhanceArticle() {
      const article = document.getElementById('article-content');
      if (!article) return;

      const calloutMap: Record<string, string> = {
        'the short version': 'callout-info',
        'key takeaway': 'callout-info',
        'bottom line': 'callout-info',
        'note': 'callout-info',
        'reality check': 'callout-warning',
        'warning': 'callout-warning',
        'important': 'callout-warning',
        'watch out': 'callout-warning',
        'pro tip': 'callout-success',
        'tip': 'callout-success',
        'quick answer': 'callout-success',
        'danger': 'callout-danger',
        'red flag': 'callout-danger',
        'caution': 'callout-danger',
      };

      article.querySelectorAll('blockquote').forEach((bq) => {
        const strong = bq.querySelector('strong');
        if (!strong) return;
        const text = strong.textContent?.replace(/[:\u2014]/g, '').trim().toLowerCase() || '';
        for (const [prefix, cls] of Object.entries(calloutMap)) {
          if (text.startsWith(prefix)) {
            bq.classList.add('callout', cls);
            break;
          }
        }
      });

      article.querySelectorAll('table').forEach((table) => {
        if (table.parentElement?.classList.contains('table-wrap')) return;
        const wrapper = document.createElement('div');
        wrapper.className = 'table-wrap';
        table.parentNode?.insertBefore(wrapper, table);
        wrapper.appendChild(table);
      });
    }
    enhanceArticle();
    document.addEventListener('astro:page-load', enhanceArticle);
  </script>

  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</PageLayout>
