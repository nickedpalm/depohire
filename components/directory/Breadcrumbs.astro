---
import config from '~/config';

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;
const allCrumbs = [{ label: 'Home', href: '/' }, ...crumbs];
---
<nav aria-label="Breadcrumb" class="text-sm text-gray-500 mb-4">
  <ol class="flex flex-wrap items-center gap-1" itemscope itemtype="https://schema.org/BreadcrumbList">
    {allCrumbs.map((crumb, i) => (
      <li class="flex items-center" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        {i > 0 && <span class="mx-1 text-gray-300">/</span>}
        {crumb.href ? (
          <a href={crumb.href} itemprop="item" class="hover:text-gray-700">
            <span itemprop="name">{crumb.label}</span>
          </a>
        ) : (
          <span itemprop="name" class="text-gray-700 font-medium">{crumb.label}</span>
        )}
        <meta itemprop="position" content={String(i + 1)} />
      </li>
    ))}
  </ol>
</nav>
