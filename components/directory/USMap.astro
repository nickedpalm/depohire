---
/**
 * Interactive US Map — shows state listing density with clickable paths.
 * Only rendered on /states/all/. Real cartographic paths from US Census via us-atlas.
 * Density tiers: 0 = gray, 1-4 = accent-100, 5-8 = accent-300, 9+ = accent-500
 */
import citiesData from '~/data/cities.json';
import { getListingCountByCity } from '~/lib/listings';
import { statePaths } from './statePathData';

const cityCounts = getListingCountByCity();

// Aggregate listing counts per state abbreviation
const stateListingCounts: Record<string, number> = {};
const stateSlugs: Record<string, string> = {};
for (const city of citiesData) {
  stateListingCounts[city.state] = (stateListingCounts[city.state] || 0) + (cityCounts[city.slug] || 0);
  if (!stateSlugs[city.state]) stateSlugs[city.state] = city.stateSlug;
}

function densityClass(abbr: string): string {
  const count = stateListingCounts[abbr] || 0;
  if (count === 0) return 'fill-gray-100 stroke-gray-300';
  if (count < 5) return 'fill-accent-100 stroke-accent-200';
  if (count < 9) return 'fill-accent-300 stroke-accent-400';
  return 'fill-accent-500 stroke-accent-600';
}

function stateHref(abbr: string): string {
  return stateSlugs[abbr] ? `/states/${stateSlugs[abbr]}/` : '#';
}

function stateTitle(abbr: string, name: string): string {
  const count = stateListingCounts[abbr] || 0;
  return `${name}: ${count} videographer${count !== 1 ? 's' : ''}`;
}

const states = statePaths;
---

<div class="mb-8">
  <h2 class="text-2xl font-heading font-bold text-center mb-4">Browse by State</h2>
  <div class="relative max-w-3xl mx-auto">
    <svg viewBox="0 0 960 600" class="w-full h-auto" role="img" aria-label="US Map showing videographer coverage by state">
      {states.map(({ abbr, name, d }) => (
        <a href={stateHref(abbr)}>
          <path
            d={d}
            class={`${densityClass(abbr)} stroke-1 hover:fill-accent-400 hover:stroke-accent-500 transition-colors cursor-pointer`}
          >
            <title>{stateTitle(abbr, name)}</title>
          </path>
        </a>
      ))}
    </svg>
    <div class="flex items-center justify-center gap-4 mt-3 text-xs text-muted">
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-sm bg-gray-100 border border-gray-300"></span> 0</span>
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-sm bg-accent-100 border border-accent-200"></span> 1-4</span>
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-sm bg-accent-300 border border-accent-400"></span> 5-8</span>
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-sm bg-accent-500 border border-accent-600"></span> 9+</span>
    </div>
  </div>
</div>
