---
interface StateEntry {
  stateSlug: string;
  stateName: string;
  state: string;
  cityCount: number;
  listingCount: number;
}

interface Props {
  states: StateEntry[];
}

const { states } = Astro.props;

// High-volume: states with the most listings (top tier)
const highVolume = states
  .filter(s => s.listingCount >= 8)
  .sort((a, b) => b.listingCount - a.listingCount);
---
<section class="container-narrow py-12">
  <h2 class="text-2xl font-heading font-bold text-gray-900 mb-6">Browse by State</h2>

  {highVolume.length > 0 && (
    <div class="mb-6">
      <h3 class="text-sm font-semibold uppercase tracking-wider text-muted mb-3">High-Volume Jurisdictions</h3>
      <div class="flex flex-wrap gap-2">
        {highVolume.map(s => (
          <a href={`/states/${s.stateSlug}/`} class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-accent-50 text-accent-700 text-sm font-medium hover:bg-accent-100 transition-colors no-underline">
            {s.stateName}
            <span class="text-xs text-accent-500">{s.listingCount}</span>
          </a>
        ))}
      </div>
    </div>
  )}

  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
    {states.map((s) => (
      <a href={`/states/${s.stateSlug}/`} class="card p-4 no-underline hover:border-accent-300 group">
        <span class="block font-semibold text-gray-900 group-hover:text-accent-600">{s.stateName}</span>
        <span class="text-sm text-gray-500">{s.cityCount} {s.cityCount === 1 ? 'city' : 'cities'}</span>
        {s.listingCount > 0 && (
          <span class="text-xs text-accent-600 ml-2">{s.listingCount} listings</span>
        )}
      </a>
    ))}
  </div>
</section>
