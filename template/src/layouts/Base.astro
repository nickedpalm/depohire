---
import config from '@/config';
import SEOHead from '@/components/SEOHead.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  schema?: object;
}

const { title, description = config.description, canonicalUrl, ogImage, schema } = Astro.props;
const fullTitle = title === config.name ? title : `${title} | ${config.name}`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <SEOHead
    title={fullTitle}
    description={description}
    canonicalUrl={canonicalUrl}
    ogImage={ogImage}
    schema={schema}
  />
</head>
<body class="min-h-screen flex flex-col">
  <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
    <nav class="container-narrow flex items-center justify-between h-16">
      <a href="/" class="text-xl font-bold text-gray-900 no-underline hover:text-primary-600">
        {config.name}
      </a>
      <div class="hidden sm:flex items-center gap-6">
        <a href="/search/" class="text-sm text-gray-600 hover:text-gray-900 no-underline">Search</a>
        <a href="/states/all/" class="text-sm text-gray-600 hover:text-gray-900 no-underline">Browse States</a>
        <a href="/blog/" class="text-sm text-gray-600 hover:text-gray-900 no-underline">Blog</a>
      </div>
      <button id="mobile-menu-btn" class="sm:hidden p-2 text-gray-600" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </nav>
    <div id="mobile-menu" class="hidden sm:hidden border-t border-gray-200 bg-white px-4 pb-4">
      <a href="/search/" class="block py-2 text-gray-600">Search</a>
      <a href="/states/all/" class="block py-2 text-gray-600">Browse States</a>
      <a href="/blog/" class="block py-2 text-gray-600">Blog</a>
    </div>
  </header>

  <main class="flex-1">
    <slot />
  </main>

  <Footer />

  <script>
    document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.toggle('hidden');
    });
  </script>
</body>
</html>
