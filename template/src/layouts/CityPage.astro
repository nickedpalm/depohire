---
import Base from './Base.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import config from '@/config';

interface Props {
  title: string;
  city: string;
  state: string;
  stateSlug: string;
  stateName?: string;
  metaDescription: string;
  schema?: object;
}

const { title, city, state, stateSlug, stateName, metaDescription, schema } = Astro.props;
---
<Base title={title} description={metaDescription} schema={schema}>
  <div class="container-narrow py-8">
    <Breadcrumbs crumbs={[
      { label: stateName || state, href: `/states/${stateSlug}/` },
      { label: city },
    ]} />
    <slot />
  </div>
</Base>
