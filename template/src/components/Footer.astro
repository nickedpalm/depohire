---
import config from '@/config';
---
<footer class="bg-gray-50 border-t border-gray-200 mt-16">
  <div class="container-narrow py-12">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
      <div>
        <h3 class="font-bold text-gray-900 mb-3">{config.name}</h3>
        <p class="text-sm text-gray-500">{config.description}</p>
      </div>
      <div>
        <h4 class="font-semibold text-gray-900 mb-3">Directory</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="text-gray-500 hover:text-gray-700 no-underline">Home</a></li>
          <li><a href="/states/all/" class="text-gray-500 hover:text-gray-700 no-underline">Browse by State</a></li>
          <li><a href="/search/" class="text-gray-500 hover:text-gray-700 no-underline">Search</a></li>
          <li><a href="/blog/" class="text-gray-500 hover:text-gray-700 no-underline">Blog</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-semibold text-gray-900 mb-3">About</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/blog/" class="text-gray-500 hover:text-gray-700 no-underline">Articles</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-gray-200 mt-8 pt-8 text-center text-sm text-gray-400">
      &copy; {new Date().getFullYear()} {config.name}. All rights reserved.
    </div>
  </div>
</footer>
