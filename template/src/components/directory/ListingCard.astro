---
import ReviewStars from './ReviewStars.astro';
import SentimentBadge from './SentimentBadge.astro';
import FeaturedBadge from './FeaturedBadge.astro';
import type { Sentiment } from '~/lib/listings';

interface Props {
  slug: string;
  name: string;
  city: string;
  state: string;
  rating: number;
  review_count: number;
  phone?: string;
  certifications?: string[];
  services?: string[];
  description?: string;
  sentiment?: Sentiment | null;
  featured?: boolean;
}

const { slug, name, city, state, rating, review_count, phone, certifications = [], services = [], description, sentiment, featured = false } = Astro.props;
const shortDesc = description && description.length > 120 ? description.slice(0, 120) + '...' : description;
---
<a href={`/listing/${slug}/`} class={`card block p-5 no-underline group ${featured ? 'ring-2 ring-amber-400 bg-amber-50/30' : ''}`}>
  <div class="flex items-start justify-between gap-3">
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2">
        <h3 class="font-semibold text-gray-900 group-hover:text-primary-600 truncate">{name}</h3>
        {featured && <FeaturedBadge size="sm" />}
      </div>
      <p class="text-sm text-gray-500 mt-0.5">{city}, {state}</p>
    </div>
    <div class="flex flex-col items-end gap-1">
      <ReviewStars rating={rating} count={review_count} size="sm" />
      {sentiment && <SentimentBadge label={sentiment.label} score={sentiment.score} size="sm" />}
    </div>
  </div>
  {shortDesc && <p class="text-sm text-gray-600 mt-2">{shortDesc}</p>}
  {sentiment && sentiment.keywords.length > 0 && (
    <div class="flex flex-wrap gap-1 mt-2">
      {sentiment.keywords.slice(0, 3).map((kw) => (
        <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs text-gray-500 bg-gray-50">{kw}</span>
      ))}
    </div>
  )}
  <div class="flex flex-wrap gap-1.5 mt-3">
    {certifications.map((cert) => (
      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">{cert}</span>
    ))}
    {services.slice(0, 3).map((svc) => (
      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">{svc}</span>
    ))}
  </div>
  {phone && <p class="text-sm text-gray-500 mt-2">{phone}</p>}
</a>
