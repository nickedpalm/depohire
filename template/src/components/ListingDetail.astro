---
import ReviewStars from './ReviewStars.astro';
import ClaimBanner from './ClaimBanner.astro';
import ReviewHighlights from './ReviewHighlights.astro';
import SentimentBadge from './SentimentBadge.astro';
import config from '@/config';
import type { Sentiment } from '@/lib/listings';

interface Props {
  listing: {
    slug: string;
    name: string;
    city: string;
    state: string;
    address: string;
    lat: number;
    lng: number;
    phone?: string;
    website?: string;
    email?: string;
    rating: number;
    review_count: number;
    description?: string;
    certifications?: string[];
    services?: string[];
    years_experience?: number;
    claimed: boolean;
    sentiment?: Sentiment | null;
  };
}

const { listing } = Astro.props;
const cityData = (await import(`@/data/cities.json`)).default.find((c: any) => c.slug === listing.city);
---
<div class="space-y-6">
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">{listing.name}</h1>
      <p class="text-gray-500 mt-1">{listing.address}</p>
      <div class="mt-2 flex items-center gap-3">
        <ReviewStars rating={listing.rating} count={listing.review_count} />
        {listing.sentiment && <SentimentBadge label={listing.sentiment.label} score={listing.sentiment.score} />}
      </div>
    </div>
    <div class="flex flex-col gap-2 sm:items-end">
      {listing.phone && (
        <a href={`tel:${listing.phone}`} class="btn-primary no-underline text-center">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          {listing.phone}
        </a>
      )}
      {listing.website && (
        <a href={listing.website} target="_blank" rel="noopener noreferrer" class="btn-outline no-underline text-center">
          Visit Website
        </a>
      )}
    </div>
  </div>

  {listing.description && (
    <div class="prose max-w-none">
      <p>{listing.description}</p>
    </div>
  )}

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {listing.certifications && listing.certifications.length > 0 && (
      <div class="card p-4">
        <h3 class="font-semibold text-sm text-gray-500 uppercase tracking-wide mb-2">Certifications</h3>
        <div class="flex flex-wrap gap-1.5">
          {listing.certifications.map((cert) => (
            <span class="inline-flex items-center px-2.5 py-1 rounded-md text-sm font-medium bg-green-100 text-green-800">{cert}</span>
          ))}
        </div>
      </div>
    )}

    {listing.services && listing.services.length > 0 && (
      <div class="card p-4">
        <h3 class="font-semibold text-sm text-gray-500 uppercase tracking-wide mb-2">Services</h3>
        <div class="flex flex-wrap gap-1.5">
          {listing.services.map((svc) => (
            <span class="inline-flex items-center px-2.5 py-1 rounded-md text-sm font-medium bg-primary-50 text-primary-700">{svc}</span>
          ))}
        </div>
      </div>
    )}

    {listing.years_experience && (
      <div class="card p-4">
        <h3 class="font-semibold text-sm text-gray-500 uppercase tracking-wide mb-2">Experience</h3>
        <p class="text-2xl font-bold text-gray-900">{listing.years_experience}+ years</p>
      </div>
    )}
  </div>

  <!-- Sentiment & Review Highlights -->
  {listing.sentiment && (
    <ReviewHighlights
      label={listing.sentiment.label}
      score={listing.sentiment.score}
      keywords={listing.sentiment.keywords}
      highlights={listing.sentiment.highlights}
      summary={listing.sentiment.summary}
    />
  )}

  <!-- Map -->
  <div class="card overflow-hidden">
    <div id="listing-map" class="h-64 w-full" data-lat={listing.lat} data-lng={listing.lng} data-name={listing.name}></div>
  </div>

  {!listing.claimed && <ClaimBanner listingName={listing.name} />}
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const el = document.getElementById('listing-map');
    if (!el) return;
    const lat = parseFloat(el.dataset.lat);
    const lng = parseFloat(el.dataset.lng);
    const name = el.dataset.name;
    const map = L.map(el).setView([lat, lng], 14);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);
    L.marker([lat, lng]).addTo(map).bindPopup(name).openPopup();
  });
</script>
